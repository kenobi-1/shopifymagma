eight:10px;\n    transition:transform .4s cubic-bezier(.4,0,.2,1);\n  }\n  .msc-faq-item.open .msc-faq-chevron svg { transform:rotate(180deg); }\n  .msc-faq-ans {\n    display:grid;\n    grid-template-rows:0fr;\n    transition:grid-template-rows .4s cubic-bezier(.4,0,.2,1);\n  }\n  .msc-faq-item.open .msc-faq-ans { grid-template-rows:1fr; }\n  .msc-faq-ans-inner {\n    overflow:hidden;\n    font-size:13px;\n    line-height:1.7;\n    color:#555;\n    padding:0 22px;\n    transition:padding .4s cubic-bezier(.4,0,.2,1);\n  }\n  .msc-faq-item.open .msc-faq-ans-inner { padding:2px 22px 18px; }\n  .msc-faq-cta {\n    display:inline-block;\n    background:#0A0A0A;\n    color:#fff;\n    font-family:'DM Sans',sans-serif;\n    font-size:13px;\n    font-weight:700;\n    letter-spacing:.12em;\n    text-transform:uppercase;\n    text-decoration:none;\n    padding:16px 40px;\n    border-radius:999px;\n    transition:background .2s,color .2s;\n    margin-top:32px;\n  }\n  .msc-faq-cta:hover { background:#F5E642; color:#0A0A0A; }\n\n  /* ─── RESPONSIVE ─── */\n  @media(max-width:1024px){\n    .msc-research { grid-template-columns:1fr; gap:40px; }\n    .msc-research-visual { display:none; }\n  }\n  @media(max-width:900px){\n    .msc-stats-grid { grid-template-columns:1fr; gap:32px; }\n    .msc-stat { border-right:none; border-bottom:1px solid #DEDEDE; padding:0 0 32px; }\n    .msc-stat:last-child { border-bottom:none; padding:0; padding-left:0; }\n    .msc-stat:nth-child(2) { padding:0 0 32px; }\n    .msc-nature-grid { grid-template-columns:repeat(2,1fr); }\n    .msc-sip { flex-direction:column; padding:60px 24px; gap:40px; }\n    .msc-sip-left { width:100%; }\n    .msc-sip-right { overflow:visible; width:100%; }\n    .msc-sip-right::after { display:none; }\n    .msc-sip-track-wrap { overflow-x:auto; -webkit-overflow-scrolling:touch; scrollbar-width:none; }\n    .msc-sip-track-wrap::-webkit-scrollbar { display:none; }\n    .msc-ing-card { width:240px; }\n    .msc-ing-card-img { height:170px; }\n    .msc-sip-nav { padding-right:0; justify-content:flex-start; }\n    .msc-faq-grid { grid-template-columns:1fr; }\n    .msc-research { padding:60px 24px; }\n  }\n  @media(max-width:600px){\n    .msc-stats { padding:56px 24px; }\n    .msc-nature { padding:60px 24px; }\n    .msc-para { padding:56px 24px; }\n    .msc-faq { padding:60px 24px; }\n    .msc-nature-grid { grid-template-columns:repeat(2,1fr); gap:28px; }\n  }\n</style>\n\n<div class=\"msc\">\n\n  <!-- HERO -->\n  <div class=\"msc-hero\">\n    <video autoplay muted loop playsinline preload=\"metadata\">\n      <source src=\"https://cdn.shopify.com/videos/c/o/v/65e44dcebf0f4b2484526b87212a2fd2.mp4\" type=\"video/mp4\">\n    </video>\n    <div class=\"msc-hero-overlay\"></div>\n    <div class=\"msc-hero-text\">\n      <h1>Cafeína natural con respaldo científico para rendimiento cognitivo real</h1>\n    </div>\n  </div>\n\n  <!-- STATS -->\n  <div class=\"msc-stats\">\n    <div class=\"msc-stats-inner\">\n      <h2>Respaldado por la investigación</h2>\n      <div class=\"msc-stats-grid\">\n        <div class=\"msc-stat\">\n          <span class=\"msc-stat-num\">100mg</span>\n          <span class=\"msc-stat-desc\">de cafeína natural por bolsita — la dosis exacta para foco máximo sin ansiedad</span>\n        </div>\n        <div class=\"msc-stat\">\n          <span class=\"msc-stat-num\">5–10</span>\n          <span class=\"msc-stat-desc\">minutos para el primer efecto. Absorción sublingual directa al torrente sanguíneo</span>\n        </div>\n        <div class=\"msc-stat\">\n          <span class=\"msc-stat-num\">0</span>\n          <span class=\"msc-stat-desc\">nicotina, calorías ni azúcar. Solo ingredientes activos que hacen lo que prometemos</span>\n        </div>\n      </div>\n      <p class=\"msc-stats-note\">*Datos basados en la fórmula MAGMA y estudios publicados sobre cafeína natural y L-teanina.</p>\n    </div>\n  </div>\n\n  <!-- BENEFITS ICONS -->\n  <div class=\"msc-nature\">\n    <h2>Potenciado por la naturaleza</h2>\n    <div class=\"msc-nature-grid\">\n      <div class=\"msc-nature-item\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/white-benefit-icon-001.webp?v=1776812897\" alt=\"Foco intenso\">\n        <span class=\"msc-nature-label\">Foco<br>Intenso</span>\n      </div>\n      <div class=\"msc-nature-item\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/white-benefit-icon-002.webp?v=1776812897\" alt=\"Memoria potenciada\">\n        <span class=\"msc-nature-label\">Memoria<br>Potenciada</span>\n      </div>\n      <div class=\"msc-nature-item\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/white-benefit-icon-003.webp?v=1776812898\" alt=\"Energía sostenida\">\n        <span class=\"msc-nature-label\">Energía<br>Sostenida</span>\n      </div>\n      <div class=\"msc-nature-item\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/white-benefit-icon-004.webp?v=1776812898\" alt=\"Sin bajón\">\n        <span class=\"msc-nature-label\">Sin<br>Bajón</span>\n      </div>\n    </div>\n  </div>\n\n  <!-- PARAGRAPH -->\n  <div class=\"msc-para\">\n    <p>Cada ingrediente de la fórmula MAGMA fue seleccionado con precisión científica para un solo objetivo: resultados medibles. Usamos cafeína natural de grano de café verde combinada con vitaminas del grupo B y L-teanina en dosis clínicamente relevantes. Esto no es suplementación al azar. Es mejora cognitiva deliberada, limpia y sin costo para tu cuerpo.</p>\n  </div>\n\n  <!-- SCIENCE IN A POUCH -->\n  <div class=\"msc-sip\">\n    <div class=\"msc-sip-left\">\n      <h2>Ciencia en una bolsita</h2>\n      <p>Experimentá foco inmediato e intenso con una fórmula de cafeína natural y vitaminas absorbidas de forma sublingual en 5 minutos o menos.</p>\n      <div class=\"msc-sip-badges\">\n        <div class=\"msc-sip-badge\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Icon_1.svg?v=1776778561\" alt=\"\">\n          <span>Cafeína Natural</span>\n        </div>\n        <div class=\"msc-sip-badge\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Icon_2.svg?v=1776778561\" alt=\"\">\n          <span>Ingredientes Premium</span>\n        </div>\n        <div class=\"msc-sip-badge\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Icon_3.svg?v=1776778560\" alt=\"\">\n          <span>Sin Nicotina</span>\n        </div>\n        <div class=\"msc-sip-badge\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Icon_4.svg?v=1776778560\" alt=\"\">\n          <span>Vitaminas B</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"msc-sip-right\">\n      <div class=\"msc-sip-track-wrap\" id=\"msc-wrap\">\n        <div class=\"msc-sip-track\" id=\"msc-track\">\n\n          <div class=\"msc-ing-card\">\n            <img class=\"msc-ing-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/PARAXANTHINE_1.webp?v=1776873875\" alt=\"Cafeína Natural\">\n            <div class=\"msc-ing-card-body\">\n              <div class=\"msc-ing-card-name\">Cafeína Natural</div>\n              <div class=\"msc-ing-tags\"><span class=\"msc-ing-tag\">ENERGÍA</span><span class=\"msc-ing-tag\">FOCO</span><span class=\"msc-ing-tag\">RENDIMIENTO</span></div>\n              <p class=\"msc-ing-card-desc\">100mg de cafeína natural de granos de café verde. Absorción sublingual para efecto rápido, limpio y sostenido sin crash.</p>\n            </div>\n          </div>\n\n          <div class=\"msc-ing-card\">\n            <img class=\"msc-ing-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/L-THEANINE_1.webp?v=1776874821\" alt=\"L-Teanina\">\n            <div class=\"msc-ing-card-body\">\n              <div class=\"msc-ing-card-name\">L-Teanina</div>\n              <div class=\"msc-ing-tags\"><span class=\"msc-ing-tag\">CALMA</span><span class=\"msc-ing-tag\">ATENCIÓN</span></div>\n              <p class=\"msc-ing-card-desc\">Aminoácido natural que suaviza el efecto de la cafeína, elimina la ansiedad y potencia la concentración sostenida.</p>\n            </div>\n          </div>\n\n          <div class=\"msc-ing-card\">\n            <img class=\"msc-ing-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/ALPHA-GPC_1.webp?v=1776874845\" alt=\"Alpha GPC\">\n            <div class=\"msc-ing-card-body\">\n              <div class=\"msc-ing-card-name\">Alpha GPC</div>\n              <div class=\"msc-ing-tags\"><span class=\"msc-ing-tag\">MEMORIA</span><span class=\"msc-ing-tag\">CLARIDAD</span></div>\n              <p class=\"msc-ing-card-desc\">Precursor de acetilcolina que optimiza la formación de memoria y el procesamiento cognitivo.</p>\n            </div>\n          </div>\n\n          <div class=\"msc-ing-card\">\n            <img class=\"msc-ing-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/GINSENG_1.webp?v=1776874838\" alt=\"Ginseng\">\n            <div class=\"msc-ing-card-body\">\n              <div class=\"msc-ing-card-name\">Ginseng</div>\n              <div class=\"msc-ing-tags\"><span class=\"msc-ing-tag\">VITALIDAD</span><span class=\"msc-ing-tag\">RESISTENCIA</span></div>\n              <p class=\"msc-ing-card-desc\">Adaptógeno clásico que reduce la fatiga mental y física, mejorando la resistencia al estrés y la concentración prolongada.</p>\n            </div>\n          </div>\n\n          <div class=\"msc-ing-card\">\n            <img class=\"msc-ing-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/VIT-B6_1.webp?v=1776873874\" alt=\"Vitamina B6\">\n            <div class=\"msc-ing-card-body\">\n              <div class=\"msc-ing-card-name\">Vitamina B6</div>\n              <div class=\"msc-ing-tags\"><span class=\"msc-ing-tag\">ESTADO DE ÁNIMO</span><span class=\"msc-ing-tag\">ALERTA</span></div>\n              <p class=\"msc-ing-card-desc\">Vitamina esencial para el metabolismo energético y la producción de neurotransmisores que regulan el humor y la función mental.</p>\n            </div>\n          </div>\n\n          <div class=\"msc-ing-card\">\n            <img class=\"msc-ing-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/VIT-B12.webp?v=1776873874\" alt=\"Vitamina B12\">\n            <div class=\"msc-ing-card-body\">\n              <div class=\"msc-ing-card-name\">Vitamina B12</div>\n              <div class=\"msc-ing-tags\"><span class=\"msc-ing-tag\">ENERGÍA</span><span class=\"msc-ing-tag\">MOTIVACIÓN</span></div>\n              <p class=\"msc-ing-card-desc\">Nutriente clave en la producción de dopamina y serotonina. Apoya el estado de ánimo, la motivación y los niveles de energía sostenidos.</p>\n            </div>\n          </div>\n\n        </div>\n      </div>\n      <div class=\"msc-sip-nav\">\n        <button class=\"msc-sip-btn\" id=\"msc-prev\" aria-label=\"Anterior\">\n          <svg viewBox=\"0 0 14 14\"><path d=\"M9 2L4 7l5 5\"/></svg>\n        </button>\n        <button class=\"msc-sip-btn\" id=\"msc-next\" aria-label=\"Siguiente\">\n          <svg viewBox=\"0 0 14 14\"><path d=\"M5 2l5 5-5 5\"/></svg>\n        </button>\n      </div>\n    </div>\n  </div>\n\n  <!-- RESEARCH BLOCK -->\n  <div class=\"msc-research\">\n    <div class=\"msc-research-text\">\n      <h2>Formulamos MAGMA con un objetivo: que cada ingrediente tenga un propósito medible y un mecanismo de acción real.</h2>\n      <p>No usamos propietarios que ocultan dosis. No usamos ingredientes de relleno. Cada componente de la fórmula MAGMA actúa en una vía biológica específica — absorción sublingual, metabolismo energético celular, síntesis de neurotransmisores — con dosis relevantes para producir resultados que podés sentir en minutos.</p>\n    </div>\n    <div class=\"msc-research-visual\">\n      <div class=\"msc-research-orb-wrap\">\n        <div class=\"msc-research-orb\"></div>\n        <div class=\"msc-research-orb-label\">FÓRMULA<br>MAGMA™</div>\n      </div>\n    </div>\n  </div>\n\n  <!-- FAQ -->\n  <div class=\"msc-faq\">\n    <div class=\"msc-faq-header\">\n      <h2>¿Preguntas?</h2>\n      <p>Tenemos respuestas<br>con respaldo científico.</p>\n    </div>\n    <div class=\"msc-faq-grid\">\n\n      <div class=\"msc-faq-item\">\n        <button class=\"msc-faq-q\" onclick=\"mscFaq(this)\">\n          <span>¿Qué ingredientes tiene MAGMA?</span>\n          <div class=\"msc-faq-chevron\"><svg viewBox=\"0 0 12 12\" fill=\"none\" stroke=\"#0A0A0A\" stroke-width=\"2\"><path d=\"M2 4l4 4 4-4\"/></svg></div>\n        </button>\n        <div class=\"msc-faq-ans\"><div class=\"msc-faq-ans-inner\">Cafeína natural (100mg), L-Teanina, Niacina, Vitamina B6, Vitamina B12, Cromo y excipientes naturales. Sin nicotina, sin azúcar, sin calorías.</div></div>\n      </div>\n\n      <div class=\"msc-faq-item\">\n        <button class=\"msc-faq-q\" onclick=\"mscFaq(this)\">\n          <span>¿Cómo se usa un pouch de MAGMA?</span>\n          <div class=\"msc-faq-chevron\"><svg viewBox=\"0 0 12 12\" fill=\"none\" stroke=\"#0A0A0A\" stroke-width=\"2\"><path d=\"M2 4l4 4 4-4\"/></svg></div>\n        </button>\n        <div class=\"msc-faq-ans\"><div class=\"msc-faq-ans-inner\">Colocá una bolsita entre tu labio y encía. Dejala actuar 20-60 minutos mientras la cafeína se absorbe de forma sublingual. Luego desechala.</div></div>\n      </div>\n\n      <div class=\"msc-faq-item\">\n        <button class=\"msc-faq-q\" onclick=\"mscFaq(this)\">\n          <span>¿Cómo me va a hacer sentir?</span>\n          <div class=\"msc-faq-chevron\"><svg viewBox=\"0 0 12 12\" fill=\"none\" stroke=\"#0A0A0A\" stroke-width=\"2\"><path d=\"M2 4l4 4 4-4\"/></svg></div>\n        </button>\n        <div class=\"msc-faq-ans\"><div class=\"msc-faq-ans-inner\">Un impulso limpio y sostenido de energía y foco. Sin el pico brusco ni el bajón del café. La mayoría reporta mayor claridad mental en los primeros 10-15 minutos.</div></div>\n      </div>\n\n      <div class=\"msc-faq-item\">\n        <button class=\"msc-faq-q\" onclick=\"mscFaq(this)\">\n          <span>¿Contiene nicotina o tabaco?</span>\n          <div class=\"msc-faq-chevron\"><svg viewBox=\"0 0 12 12\" fill=\"none\" stroke=\"#0A0A0A\" stroke-width=\"2\"><path d=\"M2 4l4 4 4-4\"/></svg></div>\n        </button>\n        <div class=\"msc-faq-ans\"><div class=\"msc-faq-ans-inner\">No. MAGMA no contiene nicotina, tabaco ni ningún derivado. Es un suplemento dietético a base de cafeína natural. No genera dependencia química.</div></div>\n      </div>\n\n      <div class=\"msc-faq-item\">\n        <button class=\"msc-faq-q\" onclick=\"mscFaq(this)\">\n          <span>¿Cuántos pouches puedo tomar por día?</span>\n          <div class=\"msc-faq-chevron\"><svg viewBox=\"0 0 12 12\" fill=\"none\" stroke=\"#0A0A0A\" stroke-width=\"2\"><path d=\"M2 4l4 4 4-4\"/></svg></div>\n        </button>\n        <div class=\"msc-faq-ans\"><div class=\"msc-faq-ans-inner\">Recomendamos no superar 3 pouches por día. Empezá con 1 para evaluar tu tolerancia. No consumir después de las 18hs si sos sensible a la cafeína.</div></div>\n      </div>\n\n      <div class=\"msc-faq-item\">\n        <button class=\"msc-faq-q\" onclick=\"mscFaq(this)\">\n          <span>¿Afecta las encías o la boca?</span>\n          <div class=\"msc-faq-chevron\"><svg viewBox=\"0 0 12 12\" fill=\"none\" stroke=\"#0A0A0A\" stroke-width=\"2\"><path d=\"M2 4l4 4 4-4\"/></svg></div>\n        </button>\n        <div class=\"msc-faq-ans\"><div class=\"msc-faq-ans-inner\">Es normal sentir un leve hormigueo al principio. Las bolsitas están formuladas con ingredientes de grado alimentario seguros. Si tenés sensibilidad dental, consultá a tu médico antes de usar.</div></div>\n      </div>\n\n    </div>\n    <a href=\"/pages/faq\" class=\"msc-faq-cta\">MÁS PREGUNTAS →</a>\n  </div>\n\n</div>\n\n<script>\n/* FAQ */\nfunction mscFaq(btn) {\n  var item = btn.parentElement;\n  var isOpen = item.classList.contains('open');\n  document.querySelectorAll('.msc-faq-item').forEach(function(i){ i.classList.remove('open'); });\n  if (!isOpen) item.classList.add('open');\n}\n\n/* CAROUSEL */\n(function(){\n  var track = document.getElementById('msc-track');\n  var wrap  = document.getElementById('msc-wrap');\n  if (!track || !wrap) return;\n\n  var GAP    = 16;\n  var cards  = Array.from(track.children);\n  var total  = cards.length;\n  var CARD_W = 0;\n  var offset = 0;\n  var animId = null;\n  var velocity = 0;\n  var lastX = 0, lastTime = 0;\n  var isDragging = false;\n  var dragStartX = 0, dragStartOffset = 0;\n\n  function getCardW() {\n    return cards[0].getBoundingClientRect().width + GAP;\n  }\n\n  function isMobile() { return window.innerWidth <= 900; }\n\n  function init() {\n    if (isMobile()) return;\n    cards.forEach(function(c){ track.appendChild(c.cloneNode(true)); });\n    cards.forEach(function(c){ track.insertBefore(c.cloneNode(true), track.firstChild); });\n    CARD_W = getCardW();\n    offset = total * CARD_W;\n    setPos(offset, false);\n  }\n\n  function setPos(x, animate) {\n    track.style.transition = animate ? 'transform .38s cubic-bezier(.25,.46,.45,.94)' : 'none';\n    track.style.transform = 'translateX(-' + x + 'px)';\n    offset = x;\n  }\n\n  function checkBounds() {\n    CARD_W = getCardW();\n    if (offset < CARD_W) setPos(offset + total * CARD_W, false);\n    else if (offset > total * 2 * CARD_W) setPos(offset - total * CARD_W, false);\n  }\n\n  document.getElementById('msc-next').addEventListener('click', function(){\n    if (isMobile()) return;\n    CARD_W = getCardW();\n    setPos(offset + CARD_W, true);\n    setTimeout(checkBounds, 400);\n  });\n  document.getElementById('msc-prev').addEventListener('click', function(){\n    if (isMobile()) return;\n    CARD_W = getCardW();\n    setPos(offset - CARD_W, true);\n    setTimeout(checkBounds, 400);\n  });\n\n  function applyMomentum() {\n    if (Math.abs(velocity) < 0.5) {\n      CARD_W = getCardW();\n      var snapped = Math.round(offset / CARD_W) * CARD_W;\n      setPos(snapped, true);\n      setTimeout(checkBounds, 400);\n      return;\n    }\n    offset += velocity;\n    velocity *= 0.92;\n    track.style.transition = 'none';\n    track.style.transform = 'translateX(-' + offset + 'px)';\n    checkBounds();\n    animId = requestAnimationFrame(applyMomentum);\n  }\n\n  /* MOUSE */\n  wrap.addEventListener('mousedown', function(e){\n    if (isMobile()) return;\n    isDragging = true; dragStartX = e.clientX; dragStartOffset = offset;\n    lastX = e.clientX; lastTime = Date.now(); velocity = 0;\n    if (animId) cancelAnimationFrame(animId);\n    track.style.transition = 'none';\n    e.preventDefault();\n  });\n  window.addEventListener('mousemove', function(e){\n    if (!isDragging || isMobile()) return;\n    var now = Date.now(); var dt = now - lastTime || 1;\n    velocity = (lastX - e.clientX) / dt * 16;\n    lastX = e.clientX; lastTime = now;\n    offset = dragStartOffset + (dragStartX - e.clientX);\n    track.style.transform = 'translateX(-' + offset + 'px)';\n    checkBounds();\n  });\n  window.addEventListener('mouseup', function(){\n    if (!isDragging || isMobile()) return;\n    isDragging = false;\n    animId = requestAnimationFrame(applyMomentum);\n  });\n\n  /* TOUCH */\n  wrap.addEventListener('touchstart', function(e){\n    isDragging = true; dragStartX = e.touches[0].clientX; dragStartOffset = offset;\n    lastX = e.touches[0].clientX; lastTime = Date.now(); velocity = 0;\n    if (animId) cancelAnimationFrame(animId);\n    track.style.transition = 'none';\n  }, {passive:true});\n  wrap.addEventListener('touchmove', function(e){\n    if (!isDragging) return;\n    var now = Date.now(); var dt = now - lastTime || 1;\n    var cx = e.touches[0].clientX;\n    velocity = (lastX - cx) / dt * 16;\n    lastX = cx; lastTime = now;\n    offset = dragStartOffset + (dragStartX - cx);\n    track.style.transform = 'translateX(-' + offset + 'px)';\n    checkBounds();\n  }, {passive:true});\n  wrap.addEventListener('touchend', function(){\n    if (!isDragging) return;\n    isDragging = false;\n    animId = requestAnimationFrame(applyMomentum);\n  }, {passive:true});\n\n  init();\n\n  window.addEventListener('resize', function(){\n    if (!isMobile()) { CARD_W = getCardW(); offset = total * CARD_W; setPos(offset, false); }\n  });\n})();\n</script>",
        "color_scheme": "",
        "padding_top": 40,
        "padding_bottom": 52
      }
    }
  },
  "order": [
    "main",
    "custom_liquid_4GYFkJ"
  ]
