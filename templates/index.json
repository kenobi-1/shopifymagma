        "custom_liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&family=DM+Sans:wght@400;500;600&display=swap');\n\n  .rv-section {\n    background: #ffffff;\n    padding: 80px 0 60px;\n    font-family: 'DM Sans', sans-serif;\n    overflow: hidden;\n  }\n\n  .rv-header {\n    padding: 0 64px;\n    margin-bottom: 56px;\n    display: flex;\n    align-items: flex-end;\n    justify-content: space-between;\n    gap: 24px;\n  }\n\n  .rv-title {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-weight: 900;\n    font-size: clamp(48px, 6vw, 88px);\n    line-height: 0.88;\n    letter-spacing: -0.02em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    margin: 0;\n  }\n\n  .rv-rating {\n    display: flex;\n    flex-direction: column;\n    align-items: flex-end;\n    gap: 4px;\n    flex-shrink: 0;\n  }\n\n  .rv-rating-top {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n\n  .rv-rating-num {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-weight: 900;\n    font-size: 48px;\n    line-height: 1;\n    color: #0A0A0A;\n    letter-spacing: -0.02em;\n  }\n\n  .rv-stars-big {\n    color: #F5C518;\n    font-size: 24px;\n    letter-spacing: 2px;\n    line-height: 1;\n  }\n\n  .rv-rating-sub {\n    font-size: 11px;\n    font-weight: 600;\n    letter-spacing: 0.16em;\n    text-transform: uppercase;\n    color: #AAAAAA;\n  }\n\n  .rv-track-outer {\n    overflow: hidden;\n    position: relative;\n    mask-image: linear-gradient(to right, transparent, black 4%, black 96%, transparent);\n    -webkit-mask-image: linear-gradient(to right, transparent, black 4%, black 96%, transparent);\n  }\n\n  .rv-track {\n    display: flex;\n    gap: 16px;\n    width: max-content;\n    cursor: grab;\n    user-select: none;\n  }\n  .rv-track:active { cursor: grabbing; }\n\n  .rv-card {\n    width: 320px;\n    flex-shrink: 0;\n    background: #F8F8F8;\n    padding: 28px;\n    display: flex;\n    flex-direction: column;\n    justify-content: space-between;\n    gap: 20px;\n  }\n\n  .rv-card-stars {\n    color: #F5C518;\n    font-size: 16px;\n    letter-spacing: 2px;\n    margin-bottom: 14px;\n    display: block;\n  }\n\n  .rv-card-text {\n    font-size: 14px;\n    line-height: 1.7;\n    color: #333333;\n  }\n\n  .rv-card-bottom {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 12px;\n    padding-top: 20px;\n    border-top: 1px solid #EEEEEE;\n  }\n\n  .rv-card-name {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-weight: 900;\n    font-size: 17px;\n    letter-spacing: 0.02em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n  }\n\n  .rv-card-flavor {\n    display: flex;\n    align-items: center;\n    gap: 5px;\n    font-size: 9px;\n    font-weight: 700;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    padding: 5px 10px;\n    border-radius: 20px;\n    white-space: nowrap;\n  }\n  .rv-card-flavor.menta  { background: rgba(0,201,192,0.1); color: #00968F; }\n  .rv-card-flavor.cherry { background: rgba(220,38,38,0.08); color: #B91C1C; }\n  .rv-card-flavor::before { content: '✓'; font-size: 9px; }\n\n  .rv-footer {\n    padding: 36px 64px 0;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n  }\n\n  .rv-cta {\n    display: inline-flex;\n    align-items: center;\n    gap: 12px;\n    background: #0A0A0A;\n    color: #ffffff;\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 0.16em;\n    text-transform: uppercase;\n    text-decoration: none;\n    padding: 16px 32px;\n    transition: background 0.2s;\n  }\n  .rv-cta:hover { background: #00C9C0; }\n\n  .rv-nav { display: flex; gap: 10px; }\n\n  .rv-nav-btn {\n    width: 44px;\n    height: 44px;\n    border: 1px solid #DDDDDD;\n    background: #ffffff;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: background 0.2s, border-color 0.2s;\n  }\n  .rv-nav-btn:hover { background: #0A0A0A; border-color: #0A0A0A; }\n  .rv-nav-btn:hover svg { stroke: #ffffff; }\n  .rv-nav-btn svg { stroke: #0A0A0A; transition: stroke 0.2s; }\n\n  @media (max-width: 768px) {\n    .rv-header { padding: 0 24px; flex-direction: column; align-items: flex-start; }\n    .rv-rating { align-items: flex-start; }\n    .rv-footer { padding: 24px 24px 0; flex-direction: column; align-items: flex-start; gap: 20px; }\n    .rv-card { width: 270px; }\n  }\n</style>\n\n<section class=\"rv-section\">\n  <div class=\"rv-header\">\n    <h2 class=\"rv-title\">LO QUE DICE<br>LA GENTE</h2>\n    <div class=\"rv-rating\">\n      <div class=\"rv-rating-top\">\n        <div class=\"rv-rating-num\">4.9</div>\n        <div class=\"rv-stars-big\">★★★★★</div>\n      </div>\n      <div class=\"rv-rating-sub\">+200 reseñas</div>\n    </div>\n  </div>\n\n  <div class=\"rv-track-outer\">\n    <div class=\"rv-track\" id=\"rv-track\">\n\n      <!-- SET 1 -->\n      <div class=\"rv-card\"><div><span class=\"rv-card-stars\">★★★★★</span><p class=\"rv-card-text\">Lo uso después del almuerzo todos los días y el bajón de las 3pm desapareció. Antes dependía del café pero me dejaba sin dormir.</p></div><div class=\"rv-card-bottom\"><div class=\"rv-card-name\">Maximiliano R.</div><div class=\"rv-card-flavor menta\">Menta</div></div></div>\n\n      <div class=\"rv-card\"><div><span class=\"rv-card-stars\">★★★★★</span><p class=\"rv-card-text\">Me sorprendió que funcione de verdad. Noto la diferencia en 5-10 minutos y es muy suave. No me da ansiedad como el café.</p></div><div class=\"rv-card-bottom\"><div class=\"rv-card-name\">Josefina K.</div><div class=\"rv-card-flavor menta\">Menta</div></div></div>\n\n      <div class=\"rv-card\"><div><span class=\"rv-card-stars\">★★★★★</span><p class=\"rv-card-text\">Si buscás foco instantáneo en un pouch, esto es. Hacía mucho que no me sentía tan concentrado. Game changer para estudiar.</p></div><div class=\"rv-card-bottom\"><div class=\"rv-card-name\">Kevin P.</div><div class=\"rv-card-flavor cherry\">Cherry</div></div></div>\n\n      <div class=\"rv-card\"><div><span class=\"rv-card-stars\">★★★★★</span><p class=\"rv-card-text\">Intenté bajar el consumo de cafeína 3 veces y fallé. Con MAGMA puedo controlar exactamente cuánto tomo. Sin crash.</p></div><div class=\"rv-card-bottom\"><div class=\"rv-card-name\">Dwarkesh S.</div><div class=\"rv-card-flavor cherry\">Cherry</div></div></div>\n\n      <div class=\"rv-card\"><div><span class=\"rv-card-stars\">★★★★★</span><p class=\"rv-card-text\">Estoy OBSESIONADA con los pouches de menta. Los uso todos los días, en el trabajo y en el gym. Energía dura horas.</p></div><div class=\"rv-card-bottom\"><div class=\"rv-card-name\">Claudia T.</div><div class=\"rv-card-flavor menta\">Menta</div></div></div>\n\n      <div class=\"rv-card\"><div><span class=\"rv-card-stars\">★★★★★</span><p class=\"rv-card-text\">Lo llevo en el bolsillo a todos lados. Para el ranked de noche, finales, pre-gym. Sin lata, sin vaso, sin excusas.</p></div><div class=\"rv-card-bottom\"><div class=\"rv-card-name\">Matías G.</div><div class=\"rv-card-flavor cherry\">Cherry</div></div></div>\n\n      <div class=\"rv-card\"><div><span class=\"rv-card-stars\">★★★★★</span><p class=\"rv-card-text\">Trabajo hasta las 3AM. MAGMA me ayuda a mantener el foco sin arruinar el sueño después. Mucho mejor que cualquier energizante.</p></div><div class=\"rv-card-bottom\"><div class=\"rv-card-name\">Carolina V.</div><div class=\"rv-card-flavor menta\">Menta</div></div></div>\n\n      <div class=\"rv-card\"><div><span class=\"rv-card-stars\">★★★★★</span><p class=\"rv-card-text\">El sabor cherry es increíble. Se siente el efecto en minutos y no me da ese temblor que me daban las bebidas energizantes.</p></div><div class=\"rv-card-bottom\"><div class=\"rv-card-name\">Rodrigo M.</div><div class=\"rv-card-flavor cherry\">Cherry</div></div></div>\n\n      <!-- SET 2 — duplicado para loop infinito -->\n      <div class=\"rv-card\"><div><span class=\"rv-card-stars\">★★★★★</span><p class=\"rv-card-text\">Lo uso después del almuerzo todos los días y el bajón de las 3pm desapareció. Antes dependía del café pero me dejaba sin dormir.</p></div><div class=\"rv-card-bottom\"><div class=\"rv-card-name\">Maximiliano R.</div><div class=\"rv-card-flavor menta\">Menta</div></div></div>\n\n      <div class=\"rv-card\"><div><span class=\"rv-card-stars\">★★★★★</span><p class=\"rv-card-text\">Me sorprendió que funcione de verdad. Noto la diferencia en 5-10 minutos y es muy suave. No me da ansiedad como el café.</p></div><div class=\"rv-card-bottom\"><div class=\"rv-card-name\">Josefina K.</div><div class=\"rv-card-flavor menta\">Menta</div></div></div>\n\n      <div class=\"rv-card\"><div><span class=\"rv-card-stars\">★★★★★</span><p class=\"rv-card-text\">Si buscás foco instantáneo en un pouch, esto es. Hacía mucho que no me sentía tan concentrado. Game changer para estudiar.</p></div><div class=\"rv-card-bottom\"><div class=\"rv-card-name\">Kevin P.</div><div class=\"rv-card-flavor cherry\">Cherry</div></div></div>\n\n      <div class=\"rv-card\"><div><span class=\"rv-card-stars\">★★★★★</span><p class=\"rv-card-text\">Intenté bajar el consumo de cafeína 3 veces y fallé. Con MAGMA puedo controlar exactamente cuánto tomo. Sin crash.</p></div><div class=\"rv-card-bottom\"><div class=\"rv-card-name\">Dwarkesh S.</div><div class=\"rv-card-flavor cherry\">Cherry</div></div></div>\n\n      <div class=\"rv-card\"><div><span class=\"rv-card-stars\">★★★★★</span><p class=\"rv-card-text\">Estoy OBSESIONADA con los pouches de menta. Los uso todos los días, en el trabajo y en el gym. Energía dura horas.</p></div><div class=\"rv-card-bottom\"><div class=\"rv-card-name\">Claudia T.</div><div class=\"rv-card-flavor menta\">Menta</div></div></div>\n\n      <div class=\"rv-card\"><div><span class=\"rv-card-stars\">★★★★★</span><p class=\"rv-card-text\">Lo llevo en el bolsillo a todos lados. Para el ranked de noche, finales, pre-gym. Sin lata, sin vaso, sin excusas.</p></div><div class=\"rv-card-bottom\"><div class=\"rv-card-name\">Matías G.</div><div class=\"rv-card-flavor cherry\">Cherry</div></div></div>\n\n      <div class=\"rv-card\"><div><span class=\"rv-card-stars\">★★★★★</span><p class=\"rv-card-text\">Trabajo hasta las 3AM. MAGMA me ayuda a mantener el foco sin arruinar el sueño después. Mucho mejor que cualquier energizante.</p></div><div class=\"rv-card-bottom\"><div class=\"rv-card-name\">Carolina V.</div><div class=\"rv-card-flavor menta\">Menta</div></div></div>\n\n      <div class=\"rv-card\"><div><span class=\"rv-card-stars\">★★★★★</span><p class=\"rv-card-text\">El sabor cherry es increíble. Se siente el efecto en minutos y no me da ese temblor que me daban las bebidas energizantes.</p></div><div class=\"rv-card-bottom\"><div class=\"rv-card-name\">Rodrigo M.</div><div class=\"rv-card-flavor cherry\">Cherry</div></div></div>\n\n    </div>\n  </div>\n\n  <div class=\"rv-footer\">\n    <a href=\"/collections/all\" class=\"rv-cta\">PROBARLO AHORA →</a>\n    <div class=\"rv-nav\">\n      <button class=\"rv-nav-btn\" id=\"rv-prev\" aria-label=\"Anterior\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><path d=\"M10 3L5 8L10 13\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n      </button>\n      <button class=\"rv-nav-btn\" id=\"rv-next\" aria-label=\"Siguiente\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\"><path d=\"M6 3L11 8L6 13\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>\n      </button>\n    </div>\n  </div>\n</section>\n\n<script>\n(function() {\n  var track = document.getElementById('rv-track');\n  var CARD_W = 336; // card + gap\n  var HALF = track.scrollWidth / 2;\n  var pos = HALF; // empezar en el medio del loop\n  var vel = 0;\n  var dragging = false;\n  var startX = 0;\n  var startPos = 0;\n  var animId;\n\n  function setPos(p) {\n    // loop infinito: si pasa del segundo set, volver al primero\n    if (p >= HALF + CARD_W) p -= HALF;\n    if (p <= 0) p += HALF;\n    pos = p;\n    track.style.transform = 'translateX(' + (-pos) + 'px)';\n  }\n\n  setPos(pos);\n\n  // Flechas\n  document.getElementById('rv-next').addEventListener('click', function() {\n    smoothScroll(CARD_W * 3);\n  });\n  document.getElementById('rv-prev').addEventListener('click', function() {\n    smoothScroll(-CARD_W * 3);\n  });\n\n  function smoothScroll(delta) {\n    var target = pos + delta;\n    var start = pos;\n    var t0 = null;\n    var dur = 400;\n    cancelAnimationFrame(animId);\n    function step(t) {\n      if (!t0) t0 = t;\n      var p = Math.min((t - t0) / dur, 1);\n      p = p < 0.5 ? 2*p*p : -1+(4-2*p)*p; // ease in-out\n      setPos(start + delta * p);\n      if (p < 1) animId = requestAnimationFrame(step);\n    }\n    animId = requestAnimationFrame(step);\n  }\n\n  // Mouse drag\n  track.addEventListener('mousedown', function(e) {\n    dragging = true;\n    startX = e.clientX;\n    startPos = pos;\n    vel = 0;\n    cancelAnimationFrame(animId);\n    e.preventDefault();\n  });\n\n  window.addEventListener('mousemove', function(e) {\n    if (!dragging) return;\n    var dx = startX - e.clientX;\n    vel = dx;\n    setPos(startPos + dx);\n  });\n\n  window.addEventListener('mouseup', function() {\n    if (!dragging) return;\n    dragging = false;\n    // momentum\n    var momentum = vel * 0.8;\n    smoothScroll(momentum);\n  });\n\n  // Touch drag\n  track.addEventListener('touchstart', function(e) {\n    startX = e.touches[0].clientX;\n    startPos = pos;\n    vel = 0;\n    cancelAnimationFrame(animId);\n  }, { passive: true });\n\n  track.addEventListener('touchmove', function(e) {\n    var dx = startX - e.touches[0].clientX;\n    vel = dx;\n    setPos(startPos + dx);\n  }, { passive: true });\n\n  track.addEventListener('touchend', function() {\n    var momentum = vel * 1.5;\n    smoothScroll(momentum);\n  });\n\n})();\n</script>",
