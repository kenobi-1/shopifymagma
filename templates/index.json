        "custom_liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600&display=swap');\n\n  .evo-section {\n    background: #ffffff;\n    padding: 30px 0;\n    overflow: hidden;\n    font-family: 'DM Sans', sans-serif;\n  }\n\n  .evo-inner {\n    max-width: 1400px;\n    margin: 0 auto;\n    padding: 0 64px;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    align-items: center;\n    gap: 80px;\n  }\n\n  /* LEFT — video */\n  .evo-left {\n    position: relative;\n  }\n\n  .evo-video {\n    width: 100%;\n    max-width: 580px;\n    height: auto;\n    display: block;\n    mix-blend-mode: multiply;\n  }\n\n  /* RIGHT — content */\n  .evo-right {\n    display: flex;\n    flex-direction: column;\n    gap: 0;\n  }\n\n  .evo-eyebrow {\n    font-size: 10px;\n    font-weight: 600;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    color: #00C9C0;\n    margin-bottom: 20px;\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n\n  .evo-eyebrow::before {\n    content: '';\n    width: 28px;\n    height: 1px;\n    background: #00C9C0;\n    flex-shrink: 0;\n  }\n\n  .evo-headline {\n    font-family: 'Bebas Neue', sans-serif;\n    font-size: clamp(52px, 6vw, 96px);\n    line-height: 0.88;\n    letter-spacing: -0.01em;\n    color: #0A0A0A;\n    margin: 0 0 32px 0;\n  }\n\n  .evo-body {\n    font-size: clamp(15px, 1.3vw, 17px);\n    line-height: 1.7;\n    color: #555555;\n    font-weight: 400;\n    margin: 0 0 48px 0;\n    max-width: 500px;\n  }\n\n  /* Icon grid — 2x2 */\n  .evo-icons {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 0;\n    border-top: 1px solid #E8E8E8;\n  }\n\n  .evo-icon-item {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    padding: 24px 24px 24px 0;\n    border-bottom: 1px solid #E8E8E8;\n    transition: background 0.2s;\n    cursor: default;\n  }\n\n  .evo-icon-item:nth-child(odd) {\n    border-right: 1px solid #E8E8E8;\n    padding-right: 24px;\n  }\n\n  .evo-icon-item:nth-child(even) {\n    padding-left: 24px;\n  }\n\n  .evo-icon-item:hover {\n    background: #F8F8F8;\n  }\n\n  .evo-icon-wrap {\n    width: 36px;\n    height: 36px;\n    flex-shrink: 0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .evo-icon-wrap img {\n    width: 28px;\n    height: 28px;\n    object-fit: contain;\n    filter: brightness(0);\n    opacity: 0.85;\n  }\n\n  .evo-icon-label {\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    line-height: 1.2;\n  }\n\n  /* Responsive */\n  @media (max-width: 900px) {\n    .evo-inner {\n      grid-template-columns: 1fr;\n      padding: 0 24px;\n      gap: 40px;\n    }\n    .evo-left { order: -1; }\n    .evo-video { max-width: 320px; margin: 0 auto; }\n    .evo-headline { font-size: clamp(48px, 12vw, 72px); }\n  }\n</style>\n\n<section class=\"evo-section\">\n  <div class=\"evo-inner\">\n\n    <div class=\"evo-left\">\n      <video class=\"evo-video\" autoplay muted loop playsinline preload=\"metadata\">\n        <source src=\"https://cdn.shopify.com/videos/c/o/v/6a34136cc29b4fb3a85425a1b79e22cb.mp4\" type=\"video/mp4\">\n      </video>\n    </div>\n\n    <div class=\"evo-right\">\n      \n\n      <h2 class=\"evo-headline\">LOS POUCHES<br>EVOLUCIONARON</h2>\n\n      <p class=\"evo-body\">Bienvenido al futuro de la energía. MAGMA combina 100mg de cafeína natural con vitaminas del complejo B y cromo, para darte foco limpio y energía real — sin calorías, sin azúcar, sin nicotina.</p>\n\n      <div class=\"evo-icons\">\n        <div class=\"evo-icon-item\">\n          <div class=\"evo-icon-wrap\">\n            <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Icon_1.svg?v=1776778561\" alt=\"\">\n          </div>\n          <div class=\"evo-icon-label\">Cafeína Natural</div>\n        </div>\n\n        <div class=\"evo-icon-item\">\n          <div class=\"evo-icon-wrap\">\n            <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Icon_2.svg?v=1776778561\" alt=\"\">\n          </div>\n          <div class=\"evo-icon-label\">Sin Nicotina</div>\n        </div>\n\n        <div class=\"evo-icon-item\">\n          <div class=\"evo-icon-wrap\">\n            <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Icon_3.svg?v=1776778560\" alt=\"\">\n          </div>\n          <div class=\"evo-icon-label\">Vitaminas B</div>\n        </div>\n\n        <div class=\"evo-icon-item\">\n          <div class=\"evo-icon-wrap\">\n            <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Icon_4.svg?v=1776778560\" alt=\"\">\n          </div>\n          <div class=\"evo-icon-label\">Sin Calorías</div>\n        </div>\n      </div>\n    </div>\n\n  </div>\n</section>",
