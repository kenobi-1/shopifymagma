        "custom_liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@800;900&family=Barlow:wght@400;500&display=swap');\n\n  .mhero {\n    position: relative;\n    min-height: 100vh;\n    background: #F2F0EC;\n    display: flex;\n    align-items: center;\n    overflow: hidden;\n    font-family: 'Barlow', sans-serif;\n  }\n\n  /* Grain texture overlay */\n  .mhero::before {\n    content: '';\n    position: absolute;\n    inset: 0;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E\");\n    opacity: 0.04;\n    pointer-events: none;\n    z-index: 1;\n  }\n\n  .mhero-inner {\n    position: relative;\n    z-index: 2;\n    width: 100%;\n    max-width: 1400px;\n    margin: 0 auto;\n    padding: 80px 64px;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    align-items: center;\n    min-height: 100vh;\n    gap: 0;\n  }\n\n  /* LEFT */\n  .mhero-left {\n    display: flex;\n    flex-direction: column;\n    gap: 0;\n    position: relative;\n    z-index: 3;\n  }\n\n  .mhero-eyebrow {\n    font-family: 'Barlow', sans-serif;\n    font-size: 11px;\n    font-weight: 500;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    color: #888888;\n    margin-bottom: 24px;\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n\n  .mhero-eyebrow::before {\n    content: '';\n    width: 32px;\n    height: 1px;\n    background: #00C9C0;\n  }\n\n  .mhero-headline {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-weight: 900;\n    font-size: clamp(72px, 8.5vw, 130px);\n    line-height: 0.88;\n    letter-spacing: -0.02em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    margin: 0 0 32px 0;\n  }\n\n  .mhero-headline .accent {\n    color: #00C9C0;\n    display: block;\n  }\n\n  .mhero-headline .outline {\n    -webkit-text-stroke: 2px #0A0A0A;\n    color: transparent;\n    display: block;\n  }\n\n  .mhero-sub {\n    font-size: clamp(13px, 1.2vw, 15px);\n    font-weight: 500;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    color: #555555;\n    max-width: 380px;\n    line-height: 1.7;\n    margin-bottom: 48px;\n  }\n\n  .mhero-actions {\n    display: flex;\n    align-items: center;\n    gap: 24px;\n    flex-wrap: wrap;\n  }\n\n  .mhero-btn-primary {\n    display: inline-flex;\n    align-items: center;\n    gap: 14px;\n    background: #0A0A0A;\n    color: #ffffff;\n    font-family: 'Barlow', sans-serif;\n    font-size: 12px;\n    font-weight: 700;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    text-decoration: none;\n    padding: 18px 36px;\n    transition: background 0.2s, gap 0.2s;\n    white-space: nowrap;\n  }\n\n  .mhero-btn-primary:hover {\n    background: #00C9C0;\n    gap: 20px;\n  }\n\n  .mhero-btn-primary svg {\n    width: 16px;\n    height: 16px;\n    flex-shrink: 0;\n  }\n\n  .mhero-btn-ghost {\n    font-family: 'Barlow', sans-serif;\n    font-size: 12px;\n    font-weight: 600;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    text-decoration: none;\n    border-bottom: 1px solid #0A0A0A;\n    padding-bottom: 2px;\n    transition: color 0.2s, border-color 0.2s;\n  }\n\n  .mhero-btn-ghost:hover {\n    color: #00C9C0;\n    border-color: #00C9C0;\n  }\n\n  /* Pill tags */\n  .mhero-pills {\n    display: flex;\n    gap: 8px;\n    flex-wrap: wrap;\n    margin-top: 48px;\n  }\n\n  .mhero-pill {\n    font-size: 10px;\n    font-weight: 600;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: #555555;\n    border: 1px solid #CCCCCC;\n    padding: 7px 14px;\n    background: transparent;\n    transition: border-color 0.2s, color 0.2s;\n  }\n\n  .mhero-pill:hover {\n    border-color: #00C9C0;\n 