olor: #999999;\n    text-decoration: none;\n    border-bottom: 1px solid #CCCCCC;\n    padding-bottom: 2px;\n    transition: color 0.2s;\n    white-space: nowrap;\n  }\n  .mh3-link:hover { color: #0A0A0A; border-color: #0A0A0A; }\n\n  .mh3-stats {\n    display: flex;\n    gap: 40px;\n    padding-top: 32px;\n    border-top: 1px solid rgba(0,0,0,0.1);\n  }\n\n  .mh3-stat-num {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-weight: 900;\n    font-size: 30px;\n    line-height: 1;\n    color: #0A0A0A;\n    letter-spacing: -0.02em;\n    display: block;\n  }\n\n  .mh3-stat-label {\n    font-size: 9px;\n    font-weight: 500;\n    letter-spacing: 0.16em;\n    text-transform: uppercase;\n    color: #AAAAAA;\n    display: block;\n    margin-top: 4px;\n  }\n\n  /* RIGHT */\n  .mh3-right {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 60px 0;\n    position: relative;\n  }\n\n  .mh3-right::before {\n    content: '';\n    position: absolute;\n    left: 0;\n    top: 15%;\n    height: 70%;\n    width: 1px;\n    background: rgba(0,0,0,0.1);\n  }\n\n  .mh3-video {\n    width: 100%;\n    max-width: 520px;\n    height: auto;\n    display: block;\n    mix-blend-mode: multiply;\n  }\n\n  /* MOBILE */\n  @media (max-width: 768px) {\n    .mh3-inner {\n      grid-template-columns: 1fr;\n      min-height: auto;\n      gap: 0;\n      padding: 0 24px;\n    }\n\n    .mh3-left {\n      padding: 80px 0 32px;\n      order: 2;\n    }\n\n    .mh3-right {\n      order: 1;\n      padding: 80px 0 0;\n    }\n\n    .mh3-right::before { display: none; }\n\n    .mh3-video {\n      max-width: 280px;\n      margin: 0 auto;\n    }\n\n    .mh3-title {\n      font-size: clamp(64px, 18vw, 100px);\n    }\n\n    .mh3-actions {\n      flex-wrap: wrap;\n      gap: 16px;\n      margin-bottom: 40px;\n    }\n\n    .mh3-stats {\n      gap: 24px;\n    }\n\n    .mh3-stat-num { font-size: 24px; }\n  }\n</style>\n\n<section class=\"mh3\">\n  <div class=\"mh3-inner\">\n