        "custom_liquid": "<style>.product-form__submit span{font-size:0!important;line-height:0;}.product-form__submit span::after{content:\"Comprar ahora\";font-size:16px;}</style><script>document.addEventListener('DOMContentLoaded',function(){document.querySelectorAll('form[action=\"/cart/add\"]').forEach(function(f){f.addEventListener('submit',function(e){e.preventDefault();var fd=new FormData(f);fetch('/cart/add',{method:'POST',body:fd}).then(function(){window.location='/checkout';});});});});</script>",
