      "settings": {
        "custom_liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&family=DM+Sans:wght@400;500&display=swap');\n\n  .mfocus-section {\n    background: #ffffff;\n    padding: 80px 40px 72px;\n    font-family: 'DM Sans', sans-serif;\n    overflow: hidden;\n  }\n\n  /* TYPEWRITER TITLE */\n  .mfocus-title {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-weight: 900;\n    font-size: clamp(48px, 7vw, 96px);\n    line-height: 1.0;\n    letter-spacing: -0.01em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    text-align: center;\n    margin: 0 0 72px;\n    min-height: 2.1em;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .mfocus-line1 {\n    display: block;\n    color: #0A0A0A;\n  }\n\n  .mfocus-line2 {\n    display: block;\n    color: #0A0A0A;\n    min-height: 1.05em;\n  }\n\n  .mfocus-cursor {\n    display: inline-block;\n    width: 3px;\n    height: 0.85em;\n    background: #00C9C0;\n    margin-left: 4px;\n    vertical-align: middle;\n    animation: mfocus-blink 0.7s step-end infinite;\n  }\n\n  @keyframes mfocus-blink {\n    0%, 100% { opacity: 1; }\n    50% { opacity: 0; }\n  }\n\n  /* BENEFITS GRID */\n  .mfocus-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 0;\n    max-width: 1200px;\n    margin: 0 auto;\n  }\n\n  .mfocus-item {\n    padding: 0 32px 0 0;\n    border-bottom: 1.5px solid #0A0A0A;\n    padding-bottom: 24px;\n  }\n\n  .mfocus-item:last-child {\n    padding-right: 0;\n  }\n\n  .mfocus-icon {\n    width: 52px;\n    height: 52px;\n    object-fit: contain;\n    margin-bottom: 16px;\n    filter: invert(1);\n  }\n\n  .mfocus-item-title {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-weight: 900;\n    font-size: 18px;\n    letter-spacing: 0.04em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    margin: 0 0 10px;\n  }\n\n  .mfocus-item-body {\n    font-size: 14px;\n    line-height: 1.6;\n    color: #555555;\n    margin: 0;\n  }\n\n  @media (max-width: 768px) {\n    .mfocus-section { padding: 60px 24px 56px; }\n    .mfocus-grid { grid-template-columns: repeat(2, 1fr); gap: 40px 24px; }\n    .mfocus-item { padding-right: 0; border-bottom: 1.5px solid #0A0A0A; }\n  }\n\n  @media (max-width: 480px) {\n    .mfocus-grid { grid-template-columns: 1fr; }\n  }\n</style>\n\n<section class=\"mfocus-section\">\n\n  <h2 class=\"mfocus-title\">\n    <span class=\"mfocus-line1\">ENFOCATE</span>\n    <span class=\"mfocus-line2\" id=\"mfocus-typed\">&nbsp;<span class=\"mfocus-cursor\"></span></span>\n  </h2>\n\n  <div class=\"mfocus-grid\">\n    <div class=\"mfocus-item\">\n      <img class=\"mfocus-icon\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/white-benefit-icon-001.webp?v=1776812897\" alt=\"Foco intenso\">\n      <div class=\"mfocus-item-title\">Foco Intenso</div>\n      <p class=\"mfocus-item-body\">La cafeína natural y las vitaminas B activan tu claridad mental en minutos para que rindas al máximo.</p>\n    </div>\n    <div class=\"mfocus-item\">\n      <img class=\"mfocus-icon\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/white-benefit-icon-002.webp?v=1776812897\" alt=\"Energía sostenida\">\n      <div class=\"mfocus-item-title\">Energía Sostenida</div>\n      <p class=\"mfocus-item-body\">Sin picos ni bajones. La absorción sublingual entrega energía limpia y constante por 1-2 horas.</p>\n    </div>\n    <div class=\"mfocus-item\">\n      <img class=\"mfocus-icon\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/white-benefit-icon-003.webp?v=1776812898\" alt=\"Sin calorías\">\n      <div class=\"mfocus-item-title\">Sin Calorías</div>\n      <p class=\"mfocus-item-body\">Cero azúcar, cero calorías, cero nicotina. Solo lo que necesitás para rendir, nada de lo que no.</p>\n    </div>\n    <div class=\"mfocus-item\">\n      <img class=\"mfocus-icon\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/white-benefit-icon-004.webp?v=1776812898\" alt=\"Vitaminas B\">\n      <div class=\"mfocus-item-title\">Vitaminas B + Cromo</div>\n      <p class=\"mfocus-item-body\">Niacina, B6, B12 y Cromo apoyan el metabolismo energético y el equilibrio del estado de ánimo.</p>\n    </div>\n  </div>\n\n</section>\n\n<script>\n(function() {\n  var el = document.getElementById('mfocus-typed');\n  if (!el) return;\n\n  var phrases = [\n    'EN 5 MINUTOS',\n    'POR 1-2 HORAS',\n    'A DEMANDA',\n    'SIN CRASH',\n    'SIN NICOTINA'\n  ];\n\n  var phraseIndex = 0;\n  var charIndex = 0;\n  var deleting = false;\n  var pauseTime = 0;\n\n  function getHTML(text) {\n    return text + '<span class=\"mfocus-cursor\"></span>';\n  }\n\n  function tick() {\n    var current = phrases[phraseIndex];\n\n    if (pauseTime > 0) {\n      pauseTime -= 16;\n      setTimeout(tick, 16);\n      return;\n    }\n\n    if (!deleting) {\n      charIndex++;\n      el.innerHTML = getHTML(current.slice(0, charIndex));\n      if (charIndex === current.length) {\n        deleting = true;\n        pauseTime = 1800;\n        setTimeout(tick, 16);\n      } else {\n        setTimeout(tick, 80);\n      }\n    } else {\n      charIndex--;\n      el.innerHTML = getHTML(current.slice(0, charIndex));\n      if (charIndex === 0) {\n        deleting = false;\n        phraseIndex = (phraseIndex + 1) % phrases.length;\n        pauseTime = 300;\n        setTimeout(tick, 16);\n      } else {\n        setTimeout(tick, 40);\n      }\n    }\n  }\n\n  setTimeout(tick, 600);\n})();\n</script>",
