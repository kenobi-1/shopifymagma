      "settings": {
        "custom_liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&family=DM+Sans:wght@400;600;700&display=swap');\n\n  .mc { background:#fff; padding:72px 60px; font-family:'DM Sans',sans-serif; box-sizing:border-box; }\n\n  .mc-outer {\n    display:grid;\n    grid-template-columns:320px 1fr;\n    align-items:stretch;\n    gap:0;\n  }\n\n  .mc-left {\n    display:flex;\n    flex-direction:column;\n  }\n\n  .mc-title {\n    font-family:'Barlow Condensed',sans-serif;\n    font-weight:900;\n    font-size:clamp(44px,5vw,72px);\n    line-height:.95;\n    letter-spacing:-.01em;\n    text-transform:uppercase;\n    color:#0A0A0A;\n    margin:0;\n    padding-bottom:24px;\n  }\n\n  .mc-imgwrap {\n    flex:1;\n    display:flex;\n    align-items:center;\n    justify-content:flex-start;\n    padding:16px 0 16px 20px;\n  }\n\n  .mc-imgwrap img {\n    width:210px;\n    height:auto;\n    object-fit:contain;\n    filter:drop-shadow(0 10px 28px rgba(0,0,0,.15));\n  }\n\n  .mc-right { min-width:0; overflow-x:auto; }\n\n  table.mc-t {\n    border-collapse:collapse;\n    width:100%;\n    min-width:440px;\n  }\n\n  table.mc-t thead th {\n    padding:14px 12px 18px;\n    font-size:10px;\n    font-weight:700;\n    letter-spacing:.12em;\n    text-transform:uppercase;\n    color:#0A0A0A;\n    text-align:center;\n    line-height:1.4;\n    border-bottom:2px solid #0A0A0A;\n    vertical-align:bottom;\n  }\n  table.mc-t thead th.lbl {\n    text-align:left;\n    padding-left:0;\n    min-width:170px;\n  }\n  table.mc-t thead th.hero {\n    background:#F4F4F2;\n    border-radius:8px 8px 0 0;\n    min-width:100px;\n  }\n\n  .mc-brand img {\n    height:28px;\n    width:auto;\n    display:block;\n    margin:0 auto;\n  }\n\n  table.mc-t tbody td {\n    padding:16px 12px;\n    text-align:center;\n    border-bottom:1px solid #E8E8E8;\n    vertical-align:middle;\n  }\n  table.mc-t tbody td.lbl {\n    text-align:left;\n    padding-left:0;\n    font-size:11px;\n    font-weight:700;\n    letter-spacing:.08em;\n    text-transform:uppercase;\n    color:#0A0A0A;\n  }\n  table.mc-t tbody td.hero { background:#F4F4F2; }\n  table.mc-t tbody tr:last-child td { border-bottom:none; }\n  table.mc-t tbody tr:last-child td.hero { border-radius:0 0 8px 8px; }\n\n  .ck {\n    width:26px;height:26px;background:#0A0A0A;border-radius:50%;\n    display:inline-flex;align-items:center;justify-content:center;\n  }\n  .ck svg { width:12px;height:12px; }\n  .em {\n    width:26px;height:26px;border:1.5px solid #C8C8C8;border-radius:50%;\n    display:inline-block;\n  }\n\n  /* ── MOBILE ── */\n  @media(max-width:760px){\n    .mc { padding:40px 20px; }\n\n    .mc-outer {\n      grid-template-columns:1fr;\n      gap:0;\n    }\n\n    .mc-left {\n      flex-direction:row;\n      align-items:center;\n      justify-content:space-between;\n      margin-bottom:28px;\n    }\n\n    .mc-title { font-size:36px; padding-bottom:0; }\n\n    .mc-imgwrap {\n      padding:0;\n      flex:none;\n      justify-content:flex-end;\n    }\n    .mc-imgwrap img { width:90px; }\n\n    /* tabla sin scroll horizontal */\n    .mc-right { overflow-x:visible; }\n\n    table.mc-t { min-width:unset; width:100%; }\n\n    table.mc-t thead th.lbl { min-width:0; width:40%; }\n    table.mc-t thead th { font-size:8px; padding:10px 6px 14px; letter-spacing:.06em; }\n    table.mc-t thead th.hero { min-width:0; }\n\n    table.mc-t tbody td { padding:14px 6px; }\n    table.mc-t tbody td.lbl { font-size:9px; letter-spacing:.06em; }\n\n    .ck { width:22px; height:22px; }\n    .ck svg { width:10px; height:10px; }\n    .em { width:22px; height:22px; }\n\n    .mc-brand img { height:20px; }\n  }\n</style>\n\n<section class=\"mc\">\n  <div class=\"mc-outer\">\n\n    <div class=\"mc-left\">\n      <h2 class=\"mc-title\">CÓMO SE<br>COMPARA<br>MAGMA</h2>\n      <div class=\"mc-imgwrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/fvvrvar_un_titulo_1_b62cc93a-5f55-4cab-92b6-e701c7de2127.png?v=1776875571\" alt=\"MAGMA Energy\">\n      </div>\n    </div>\n\n    <div class=\"mc-right\">\n      <table class=\"mc-t\">\n        <thead>\n          <tr>\n            <th class=\"lbl\"></th>\n            <th class=\"hero\">\n              <div class=\"mc-brand\">\n                <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/1_2_3040498d-3d5b-4472-a892-b88457455470.png?v=1778447935\" alt=\"MAGMA ENERGY\">\n              </div>\n            </th>\n            <th>POUCHES<br>NICOTINA</th>\n            <th>CAFÉ +<br>ENERGIZANTES</th>\n            <th>OTROS<br>ESTIMULANTES</th>\n          </tr>\n        </thead>\n        <tbody>\n          <tr>\n            <td class=\"lbl\">Sin nicotina ni adicción</td>\n            <td class=\"hero\"><div class=\"ck\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M1.5 6l3 3 6-6\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div></td>\n            <td><div class=\"em\"></div></td>\n            <td><div class=\"em\"></div></td>\n            <td><div class=\"ck\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M1.5 6l3 3 6-6\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div></td>\n          </tr>\n          <tr>\n            <td class=\"lbl\">Foco instantáneo</td>\n            <td class=\"hero\"><div class=\"ck\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M1.5 6l3 3 6-6\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div></td>\n            <td><div class=\"ck\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M1.5 6l3 3 6-6\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div></td>\n            <td><div class=\"ck\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M1.5 6l3 3 6-6\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div></td>\n            <td><div class=\"em\"></div></td>\n          </tr>\n          <tr>\n            <td class=\"lbl\">Sin jitters ni crash</td>\n            <td class=\"hero\"><div class=\"ck\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M1.5 6l3 3 6-6\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div></td>\n            <td><div class=\"em\"></div></td>\n            <td><div class=\"em\"></div></td>\n            <td><div class=\"em\"></div></td>\n          </tr>\n          <tr>\n            <td class=\"lbl\">Sin calorías ni azúcar</td>\n            <td class=\"hero\"><div class=\"ck\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M1.5 6l3 3 6-6\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div></td>\n            <td><div class=\"ck\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M1.5 6l3 3 6-6\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div></td>\n            <td><div class=\"em\"></div></td>\n            <td><div class=\"em\"></div></td>\n          </tr>\n          <tr>\n            <td class=\"lbl\">Amigable con el sueño</td>\n            <td class=\"hero\"><div class=\"ck\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M1.5 6l3 3 6-6\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div></td>\n            <td><div class=\"em\"></div></td>\n            <td><div class=\"em\"></div></td>\n            <td><div class=\"em\"></div></td>\n          </tr>\n          <tr>\n            <td class=\"lbl\">Ingredientes naturales</td>\n            <td class=\"hero\"><div class=\"ck\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M1.5 6l3 3 6-6\" stroke=\"#fff\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></div></td>\n            <td><div class=\"em\"></div></td>\n            <td><div class=\"em\">