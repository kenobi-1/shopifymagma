        "custom_liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&family=DM+Sans:wght@400;500&display=swap');\n\n  .mhero-typed {\n    background: #ffffff;\n    padding: 80px 24px 60px;\n    text-align: center;\n  }\n  .mhero-headline {\n    margin-bottom: 72px;\n  }\n  .mhero-line1 {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-size: clamp(36px, 6vw, 80px);\n    font-weight: 900;\n    color: #0A0A0A;\n    letter-spacing: -0.01em;\n    line-height: 1;\n    text-transform: uppercase;\n  }\n  .mhero-line2 {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-size: clamp(36px, 6vw, 80px);\n    font-weight: 900;\n    color: #0A0A0A;\n    letter-spacing: -0.01em;\n    line-height: 1.1;\n    text-transform: uppercase;\n    min-height: 1.1em;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 2px;\n  }\n  .mtyped-cursor {\n    animation: mblink 0.7s infinite;\n    color: #0A0A0A;\n  }\n  @keyframes mblink {\n    0%, 100% { opacity: 1; }\n    50% { opacity: 0; }\n  }\n  .mhero-benefits {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 0;\n    max-width: 1100px;\n    margin: 0 auto;\n  }\n  .mhero-benefit {\n    padding: 0 24px;\n    border-right: 1px solid #e4e4e4;\n    text-align: left;\n  }\n  .mhero-benefit:last-child {\n    border-right: none;\n  }\n  .mhero-benefit img {\n    width: 40px;\n    height: 40px;\n    object-fit: contain;\n    margin-bottom: 14px;\n    display: block;\n    filter: invert(1);\n  }\n  .mhero-benefit-title {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-size: 13px;\n    font-weight: 900;\n    color: #0A0A0A;\n    letter-spacing: 0.06em;\n    margin-bottom: 8px;\n    text-transform: uppercase;\n  }\n  .mhero-benefit-text {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 12px;\n    line-height: 1.6;\n    color: #888;\n  }\n  @media (max-width: 700px) {\n    .mhero-benefits {\n      grid-template-columns: 1fr 1fr;\n    }\n    .mhero-benefit {\n      padding: 20px 16px;\n      border-right: none;\n      border-bottom: 1px solid #e4e4e4;\n    }\n    .mhero-benefit:nth-child(odd) {\n      border-right: 1px solid #e4e4e4;\n    }\n    .mhero-benefit:nth-last-child(-n+2) {\n      border-bottom: none;\n    }\n  }\n</style>\n\n<div class=\"mhero-typed\">\n  <div class=\"mhero-headline\">\n    <div class=\"mhero-line1\">ENERGÍA LIMPIA</div>\n    <div class=\"mhero-line2\">\n      <span id=\"mtyped\"></span><span class=\"mtyped-cursor\">|</span>\n    </div>\n  </div>\n\n  <div class=\"mhero-benefits\">\n    <div class=\"mhero-benefit\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/white-benefit-icon-001.webp?v=1776812897\" alt=\"Foco\">\n      <div class=\"mhero-benefit-title\">FOCO INMEDIATO</div>\n      <div class=\"mhero-benefit-text\">Cafeína natural absorbida de forma sublingual en minutos.</div>\n    </div>\n    <div class=\"mhero-benefit\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/white-benefit-icon-002.webp?v=1776812897\" alt=\"Energía\">\n      <div class=\"mhero-benefit-title\">ENERGÍA LIMPIA</div>\n      <div class=\"mhero-benefit-text\">Sin azúcar, sin calorías.</div>\n    </div>\n    <div class=\"mhero-benefit\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/white-benefit-icon-003.webp?v=1776812898\" alt=\"Sin nicotina\">\n      <div class=\"mhero-benefit-title\">SIN NICOTINA</div>\n      <div class=\"mhero-benefit-text\">L-Teanina y vitaminas B para concentración sostenida.</div>\n    </div>\n    <div class=\"mhero-benefit\">\n      <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/white-benefit-icon-004.webp?v=1776812898\" alt=\"Duración\">\n      <div class=\"mhero-benefit-title\">DURA 1-2 HORAS</div>\n      <div class=\"mhero-benefit-text\">Efecto estable sin picos ni bajones de energía.</div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function() {\n  var phrases = [\n    'EN 5 MINUTOS',\n    'SIN BAJÓN',\n    'SIN NICOTINA',\n    'CUANDO QUERÉS',\n    'EN UN POUCH'\n  ];\n  var el = document.getElementById('mtyped');\n  if (!el) return;\n  var pi = 0, ci = 0, deleting = false;\n  function type() {\n    var current = phrases[pi];\n    if (!deleting) {\n      el.textContent = current.substring(0, ci + 1);\n      ci++;\n      if (ci === current.length) {\n        deleting = true;\n        setTimeout(type, 1800);\n        return;\n      }\n      setTimeout(type, 80);\n    } else {\n      el.textContent = current.substring(0, ci - 1);\n      ci--;\n      if (ci === 0) {\n        deleting = false;\n        pi = (pi + 1) % phrases.length;\n        setTimeout(type, 300);\n        return;\n      }\n      setTimeout(type, 40);\n    }\n  }\n  setTimeout(type, 500);\n})();\n</script>",
