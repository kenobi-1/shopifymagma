      "settings": {
        "custom_liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&family=DM+Sans:wght@400;500;600&display=swap');\n\n  .msci-section {\n    background: #ffffff;\n    padding: 80px 0 80px 60px;\n    font-family: 'DM Sans', sans-serif;\n    display: flex;\n    align-items: flex-start;\n    gap: 64px;\n    overflow: hidden;\n    box-sizing: border-box;\n  }\n\n  /* LEFT PANEL */\n  .msci-left {\n    flex-shrink: 0;\n    width: 300px;\n    padding-top: 16px;\n  }\n\n  .msci-title {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-weight: 900;\n    font-size: clamp(48px, 5vw, 72px);\n    line-height: 0.95;\n    letter-spacing: -0.01em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    margin: 0 0 32px;\n  }\n\n  .msci-body {\n    font-size: 15px;\n    line-height: 1.7;\n    color: #444444;\n    margin: 0 0 40px;\n  }\n\n  .msci-badges {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 14px 20px;\n  }\n\n  .msci-badge {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n\n  .msci-badge img {\n    width: 20px;\n    height: 20px;\n    object-fit: contain;\n    flex-shrink: 0;\n  }\n\n  .msci-badge span {\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n  }\n\n  /* RIGHT CAROUSEL */\n  .msci-right {\n    flex: 1;\n    overflow: hidden;\n    position: relative;\n    min-width: 0;\n  }\n\n  .msci-right::before,\n  .msci-right::after {\n    content: '';\n    position: absolute;\n    top: 0;\n    bottom: 0;\n    width: 60px;\n    z-index: 2;\n    pointer-events: none;\n  }\n  .msci-right::before {\n    left: 0;\n    background: linear-gradient(to right, #ffffff, transparent);\n  }\n  .msci-right::after {\n    right: 0;\n    background: linear-gradient(to left, #ffffff, transparent);\n  }\n\n  .msci-track-wrap {\n    overflow: hidden;\n    cursor: grab;\n    user-select: none;\n  }\n  .msci-track-wrap:active { cursor: grabbing; }\n\n  .msci-track {\n    display: flex;\n    gap: 20px;\n    width: max-content;\n    transition: none;\n  }\n\n  .msci-card {\n    flex-shrink: 0;\n    width: 300px;\n    background: #F7F7F5;\n    border-radius: 4px;\n    overflow: hidden;\n  }\n\n  .msci-card-img {\n    width: 100%;\n    height: 220px;\n    object-fit: cover;\n    display: block;\n  }\n\n  .msci-card-body {\n    padding: 20px 24px 24px;\n  }\n\n  .msci-card-name {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-weight: 900;\n    font-size: 26px;\n    letter-spacing: 0.01em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    margin: 0 0 10px;\n  }\n\n  .msci-card-tags {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 6px;\n    margin-bottom: 14px;\n  }\n\n  .msci-card-tag {\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    border: 1.5px solid #0A0A0A;\n    border-radius: 999px;\n    padding: 4px 10px;\n  }\n\n  .msci-card-desc {\n    font-size: 13px;\n    line-height: 1.65;\n    color: #555555;\n    margin: 0;\n  }\n\n  /* NAV ARROWS */\n  .msci-nav {\n    display: flex;\n    gap: 10px;\n    margin-top: 24px;\n    padding-right: 60px;\n    justify-content: flex-end;\n  }\n\n  .msci-btn {\n    width: 44px;\n    height: 44px;\n    border-radius: 50%;\n    border: 1.5px solid #0A0A0A;\n    background: transparent;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: background .2s, color .2s;\n    flex-shrink: 0;\n  }\n  .msci-btn:hover { background: #0A0A0A; }\n  .msci-btn:hover svg path { stroke: #ffffff; }\n  .msci-btn svg { width: 16px; height: 16px; }\n  .msci-btn svg path { stroke: #0A0A0A; stroke-width: 2; fill: none; stroke-linecap: round; stroke-linejoin: round; }\n\n  @media (max-width: 900px) {\n    .msci-section { flex-direction: column; padding: 60px 24px 60px; gap: 48px; }\n    .msci-left { width: 100%; }\n    .msci-card { width: 260px; }\n    .msci-card-img { height: 180px; }\n  }\n</style>\n\n<section class=\"msci-section\">\n\n  <!-- LEFT -->\n  <div class=\"msci-left\">\n    <h2 class=\"msci-title\">CIENCIA<br>EN UNA<br>POUCH</h2>\n    <p class=\"msci-body\">Cafeína natural de grano de café verde y vitaminas B en una fórmula absorbida de forma sublingual. Energía real en minutos, sin crash, sin azúcar, sin nicotina.</p>\n    <div class=\"msci-badges\">\n      <div class=\"msci-badge\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Icon_1.svg?v=1776778561\" alt=\"\">\n        <span>Cafeína Natural</span>\n      </div>\n      <div class=\"msci-badge\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Icon_2.svg?v=1776778561\" alt=\"\">\n        <span>Ingredientes Premium</span>\n      </div>\n      <div class=\"msci-badge\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Icon_3.svg?v=1776778560\" alt=\"\">\n        <span>Sin Nicotina</span>\n      </div>\n      <div class=\"msci-badge\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Icon_4.svg?v=1776778560\" alt=\"\">\n        <span>Con Vitaminas B</span>\n      </div>\n    </div>\n  </div>\n\n  <!-- RIGHT CAROUSEL -->\n  <div class=\"msci-right\">\n    <div class=\"msci-track-wrap\" id=\"msci-wrap\">\n      <div class=\"msci-track\" id=\"msci-track\">\n\n        <div class=\"msci-card\">\n          <img class=\"msci-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/PARAXANTHINE_1.webp?v=1776873875\" alt=\"Cafeína Natural\">\n          <div class=\"msci-card-body\">\n            <div class=\"msci-card-name\">Cafeína Natural</div>\n            <div class=\"msci-card-tags\"><span class=\"msci-card-tag\">ENERGÍA</span><span class=\"msci-card-tag\">FOCO</span><span class=\"msci-card-tag\">RENDIMIENTO</span></div>\n            <p class=\"msci-card-desc\">100mg de cafeína natural de granos de café verde. Absorción sublingual para un efecto rápido, limpio y sostenido.</p>\n          </div>\n        </div>\n\n        <div class=\"msci-card\">\n          <img class=\"msci-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/L-THEANINE_1.webp?v=1776874821\" alt=\"L-Teanina\">\n          <div class=\"msci-card-body\">\n            <div class=\"msci-card-name\">L-Teanina</div>\n            <div class=\"msci-card-tags\"><span class=\"msci-card-tag\">CALMA</span><span class=\"msci-card-tag\">ATENCIÓN</span></div>\n            <p class=\"msci-card-desc\">Aminoácido natural que suaviza el efecto de la cafeína, eliminando la ansiedad y potenciando la concentración sostenida.</p>\n          </div>\n        </div>\n\n        <div class=\"msci-card\">\n          <img class=\"msci-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/ALPHA-GPC_1.webp?v=1776874845\" alt=\"Alpha GPC\">\n          <div class=\"msci-card-body\">\n            <div class=\"msci-card-name\">Alpha GPC</div>\n            <div class=\"msci-card-tags\"><span class=\"msci-card-tag\">MEMORIA</span><span class=\"msci-card-tag\">CLARIDAD</span></div>\n            <p class=\"msci-card-desc\">Precursor de acetilcolina que optimiza la formación de memoria, la plasticidad sináptica y el procesamiento cognitivo.</p>\n          </div>\n        </div>\n\n        <div class=\"msci-card\">\n          <img class=\"msci-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/GINSENG_1.webp?v=1776874838\" alt=\"Ginseng\">\n          <div class=\"msci-card-body\">\n            <div class=\"msci-card-name\">Ginseng</div>\n            <div class=\"msci-card-tags\"><span class=\"msci-card-tag\">VITALIDAD</span><span class=\"msci-card-tag\">RESISTENCIA</span></div>\n            <p class=\"msci-card-desc\">Adaptógeno clásico que reduce la fatiga mental y física, mejorando la resistencia al estrés y la concentración prolongada.</p>\n          </div>\n        </div>\n\n        <div class=\"msci-card\">\n          <img class=\"msci-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/VIT-B6_1.webp?v=1776873874\" alt=\"Vitamina B6\">\n          <div class=\"msci-card-body\">\n            <div class=\"msci-card-name\">Vitamina B6</div>\n            <div class=\"msci-card-tags\"><span class=\"msci-card-tag\">ESTADO DE ÁNIMO</span><span class=\"msci-card-tag\">ALERTA</span></div>\n            <p class=\"msci-card-desc\">Vitamina esencial para el metabolismo energético y la producción de neurotransmisores que regulan el humor y la función mental.</p>\n          </div>\n        </div>\n\n        <div class=\"msci-card\">\n          <img class=\"msci-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/VIT-B12.webp?v=1776873874\" alt=\"Vitamina B12\">\n          <div class=\"msci-card-body\">\n            <div class=\"msci-card-name\">Vitamina B12</div>\n            <div class=\"msci-card-tags\"><span class=\"msci-card-tag\">ENERGÍA</span><span class=\"msci-card-tag\">MOTIVACIÓN</span></div>\n            <p class=\"msci-card-desc\">Nutriente clave en la producción de dopamina y serotonina. Apoya el estado de ánimo, la motivación y los niveles de energía sostenidos.</p>\n          </div>\n        </div>\n\n      </div>\n    </div>\n\n    <div class=\"msci-nav\">\n      <button class=\"msci-btn\" id=\"msci-prev\" aria-label=\"Anterior\">\n        <svg viewBox=\"0 0 16 16\"><path d=\"M10 3L5 8l5 5\"/></svg>\n      </button>\n      <button class=\"msci-btn\" id=\"msci-next\" aria-label=\"Siguiente\">\n        <svg viewBox=\"0 0 16 16\"><path d=\"M6 3l5 5-5 5\"/></svg>\n      </button>\n    </div>\n  </div>\n\n</section>\n\n<script>\n(function() {\n  var track = document.getElementById('msci-track');\n  var wrap  = document.getElementById('msci-wrap');\n  if (!track || !wrap) return;\n\n  var CARD_W = 300 + 20; // card + gap\n  var offset = 0;\n  var cards  = Array.from(track.children);\n  var total  = cards.length;\n\n  // Clone for infinite loop\n  cards.forEach(function(c) { track.appendChild(c.cloneNode(true)); });\n  cards.forEach(function(c) { track.insertBefore(c.cloneNode(true), track.firstChild); });\n\n  // Start at first real card\n  offset = total * CARD_W;\n  track.style.transform = 'translateX(-' + offset + 'px)';\n\n  function moveTo(newOffset, animate) {\n    track.style.transition = animate ? 'transform 0.4s cubic-bezier(0.25,0.46,0.45,0.94)' : 'none';\n    track.style.transform  = 'translateX(-' + newOffset + 'px)';\n    offset = newOffset;\n  }\n\n  function onTransitionEnd() {\n    var allCards = total * 3;\n    if (offset <= 0) {\n      moveTo(total * CARD_W, false);\n    } else if (offset >= total * 2 * CARD_W) {\n      moveTo(total * CARD_W, false);\n    }\n  }\n  track.addEventListener('transitionend', onTransitionEnd);\n\n  document.getElementById('msci-next').addEventListener('click', function() {\n    moveTo(offset + CARD_W, true);\n  });\n  document.getElementById('msci-prev').addEventListener('click', function() {\n    moveTo(offset - CARD_W, true);\n  });\n\n  // Drag\n  var isDragging = false, startX = 0, startOffset = 0;\n  wrap.addEventListener('mousedown', function(e) {\n    isDragging = true; startX = e.clientX; startOffset = offset;\n    track.style.transition = 'none';\n  });\n  window.addEventListener('mousemove', function(e) {\n    if (!isDragging) return;\n    var diff = startX - e.clientX;\n    track.style.transform = 'translateX(-' + (startOffset + diff) + 'px)';\n  });\n  window.addEventListener('mouseup', function(e) {\n    if (!isDragging) return;\n    isDragging = false;\n    var diff = startX - e.clientX;\n    var snapped = startOffset + Math.round(diff / CARD_W) * CARD_W;\n    moveTo(snapped, true);\n  });\n\n  // Touch\n  wrap.addEventListener('touchstart', function(e) {\n    startX = e.touches[0].clientX; startOffset = offset;\n    track.style.transition = 'none';\n  }, {passive:true});\n  wrap.addEventListener('touchmove', function(e) {\n    var diff = startX - e.touches[0].clientX;\n    track.style.transform = 'translateX(-' + (startOffset + diff) + 'px)';\n  }, {passive:true});\n  wrap.addEventListener('touchend', function(e) {\n    var diff = startX - e.changedTouches[0].clientX;\n    var snapped = startOffset + Math.round(diff / CARD_W) * CARD_W;\n    moveTo(snapped, true);\n  });\n})();\n</script>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "custom_liquid_RAQem4": {
      "type": "custom-liquid",
