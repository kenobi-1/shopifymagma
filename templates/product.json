    "custom_liquid_MxUKnX": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&family=DM+Sans:wght@400;500&display=swap');\n\n  .tr-section {\n    background: #ffffff;\n    padding: 40px 0;\n    overflow: hidden;\n    font-family: 'DM Sans', sans-serif;\n  }\n\n  .tr-header {\n    padding: 0 64px;\n    margin-bottom: 48px;\n    display: flex;\n    align-items: flex-end;\n    justify-content: space-between;\n    gap: 40px;\n  }\n\n  .tr-title {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-weight: 900;\n    font-size: clamp(56px, 7vw, 100px);\n    line-height: 0.88;\n    letter-spacing: -0.02em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    margin: 0;\n  }\n\n  .tr-sub {\n    font-size: 14px;\n    line-height: 1.6;\n    color: #777777;\n    max-width: 280px;\n    text-align: right;\n    flex-shrink: 0;\n  }\n\n  /* Scrollable track */\n  .tr-track-wrap {\n    overflow-x: auto;\n    scrollbar-width: none;\n    -ms-overflow-style: none;\n    cursor: grab;\n    padding: 0 64px 8px;\n  }\n  .tr-track-wrap::-webkit-scrollbar { display: none; }\n  .tr-track-wrap:active { cursor: grabbing; }\n\n  .tr-track {\n    display: flex;\n    gap: 20px;\n    width: max-content;\n  }\n\n  .tr-card {\n    width: 340px;\n    flex-shrink: 0;\n    background: #F7F7F7;\n    display: flex;\n    flex-direction: column;\n    overflow: hidden;\n    transition: transform 0.2s;\n  }\n  .tr-card:hover { transform: translateY(-4px); }\n\n  .tr-card-img {\n    width: 100%;\n    height: 380px;\n    object-fit: cover;\n    object-position: top;\n    display: block;\n    filter: grayscale(20%);\n  }\n\n  .tr-card-body {\n    padding: 24px;\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    gap: 12px;\n  }\n\n  .tr-card-person {\n    display: flex;\n    flex-direction: column;\n    gap: 2px;\n  }\n\n  .tr-card-name {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-weight: 900;\n    font-size: 22px;\n    letter-spacing: -0.01em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    line-height: 1;\n  }\n\n  .tr-card-role {\n    font-size: 10px;\n    font-weight: 600;\n    letter-spacing: 0.16em;\n    text-transform: uppercase;\n    color: #999999;\n  }\n\n  .tr-stars {\n    color: #F5C518;\n    font-size: 14px;\n    letter-spacing: 2px;\n  }\n\n  .tr-card-quote {\n    font-size: 14px;\n    line-height: 1.65;\n    color: #444444;\n    flex: 1;\n  }\n\n  .tr-card-quote::before { content: '\"'; }\n  .tr-card-quote::after  { content: '\"'; }\n\n  /* Nav arrows */\n  .tr-nav {\n    display: flex;\n    gap: 12px;\n    padding: 32px 64px 0;\n    justify-content: flex-end;\n  }\n\n  .tr-nav-btn {\n    width: 44px;\n    height: 44px;\n    border: 1px solid #DDDDDD;\n    background: #ffffff;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: background 0.2s, border-color 0.2s;\n  }\n  .tr-nav-btn:hover { background: #0A0A0A; border-color: #0A0A0A; }\n  .tr-nav-btn:hover svg { stroke: #ffffff; }\n  .tr-nav-btn svg { stroke: #0A0A0A; transition: stroke 0.2s; }\n\n  @media (max-width: 768px) {\n    .tr-header { padding: 0 24px; flex-direction: column; align-items: flex-start; }\n    .tr-sub { text-align: left; }\n    .tr-track-wrap { padding: 0 24px 8px; }\n    .tr-nav { padding: 24px 24px 0; }\n    .tr-card { width: 280px; }\n    .tr-card-img { height: 300px; }\n  }\n</style>\n\n<section class=\"tr-section\">\n  <div class=\"tr-header\">\n    <h2 class=\"tr-title\">CONFIADO<br>POR EL TOP 1%</h2>\n    <p class=\"tr-sub\">Founders, atletas y ejecutivos de todo el mundo.</p>\n  </div>\n\n  <div class=\"tr-track-wrap\" id=\"tr-track-wrap\">\n    <div class=\"tr-track\" id=\"tr-track\">\n\n      <div class=\"tr-card\">\n        <img class=\"tr-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/1_1_1602eaa6-dd09-45ca-bc81-0c9c39e14d8f.png?v=1778886875\" alt=\"Marco R.\">\n        <div class=\"tr-card-body\">\n          <div class=\"tr-card-person\">\n            <div class=\"tr-card-name\">TOMÁS MAZZA</div>\n            <div class=\"tr-card-role\">Influencer Fitrness</div>\n          </div>\n          <div class=\"tr-stars\">★★★★★</div>\n          <div class=\"tr-card-quote\">MAGMA me da el foco que necesito para las reuniones más exigentes y los entrenamientos extensos.</div>\n        </div>\n      </div>\n\n      <div class=\"tr-card\">\n        <img class=\"tr-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/KyleLui.webp?v=1776800095\" alt=\"Sebastián T.\">\n        <div class=\"tr-card-body\">\n          <div class=\"tr-card-person\">\n            <div class=\"tr-card-name\">Sebastián Torres</div>\n            <div class=\"tr-card-role\">Partner, Kaszek</div>\n          </div>\n          <div class=\"tr-stars\">★★★★★</div>\n          <div class=\"tr-card-quote\">Reemplazó el tercer café del día. Me da energía limpia sin que se note ni en el pulso. Para mí es parte del ritual de trabajo.</div>\n        </div>\n      </div>\n\n      <div class=\"tr-card\">\n        <img class=\"tr-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/hf_20260422_205936_7640381d-c7d6-4e35-86d9-e1c089ccfa8a.png?v=1776892111\" alt=\"Lucía M.\">\n        <div class=\"tr-card-body\">\n          <div class=\"tr-card-person\">\n            <div class=\"tr-card-name\">LUCAS Mansilla</div>\n            <div class=\"tr-card-role\">Atleta profesional, CrossFit</div>\n          </div>\n          <div class=\"tr-stars\">★★★★★</div>\n          <div class=\"tr-card-quote\">Lo uso antes de los WODs más pesados. No me infla, no me pone nerviosa. Solo foco y energía real cuando más lo necesito.</div>\n        </div>\n      </div>\n\n      <div class=\"tr-card\">\n        <img class=\"tr-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/rief.webp?v=1776800095\" alt=\"Andrés V.\">\n        <div class=\"tr-card-body\">\n          <div class=\"tr-card-person\">\n            <div class=\"tr-card-name\">Andrés Villalba</div>\n            <div class=\"tr-card-role\">Co-founder, lapson</div>\n          </div>\n          <div class=\"tr-stars\">★★★★★</div>\n          <div class=\"tr-card-quote\">Estuve años dependiendo del café. MAGMA es la alternativa que no sabía que existía. Discreta, efectiva, sin los efectos secundarios.</div>\n        </div>\n      </div>\n\n      <div class=\"tr-card\">\n        <img class=\"tr-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Harley_Miller_4CSCY_1000x1405_6e8887fb-9fe7-4ac2-a1cc-94e4a571ba02.webp?v=1776800133\" alt=\"Federico P.\">\n        <div class=\"tr-card-body\">\n          <div class=\"tr-card-person\">\n            <div class=\"tr-card-name\">Federico Preti</div>\n            <div class=\"tr-card-role\">Director, trysip</div>\n          </div>\n          <div class=\"tr-stars\">★★★★★</div>\n          <div class=\"tr-card-quote\">La absorción sublingual es real. En 5 minutos estoy en modo trabajo. Lo llevo a todos lados — reuniones, viajes, gym.</div>\n        </div>\n      </div>\n\n      <div class=\"tr-card\">\n        <img class=\"tr-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/upscalemedia-transformed_1_b43f8cad-b7da-4287-84f1-12b75574292b.webp?v=1776800096\" alt=\"Carolina S.\">\n        <div class=\"tr-card-body\">\n          <div class=\"tr-card-person\">\n            <div class=\"tr-card-name\">AUGUSTO Suárez</div>\n            <div class=\"tr-card-role\">Founder, Studio CS</div>\n          </div>\n          <div class=\"tr-stars\">★★★★★</div>\n          <div class=\"tr-card-quote\">Trabajo hasta las 2 AM regularmente. MAGMA me ayuda a mantener el foco sin arruinar el sueño después. Game changer para creadores.</div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  <div class=\"tr-nav\">\n    <button class=\"tr-nav-btn\" id=\"tr-prev\" aria-label=\"Anterior\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n        <path d=\"M10 3L5 8L10 13\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </button>\n    <button class=\"tr-nav-btn\" id=\"tr-next\" aria-label=\"Siguiente\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n        <path d=\"M6 3L11 8L6 13\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </button>\n  </div>\n</section>\n\n<script>\n  (function() {\n    var wrap = document.getElementById('tr-track-wrap');\n    var prev = document.getElementById('tr-prev');\n    var next = document.getElementById('tr-next');\n    var scrollAmt = 360;\n\n    next.addEventListener('click', function() {\n      wrap.scrollBy({ left: scrollAmt, behavior: 'smooth' });\n    });\n    prev.addEventListener('click', function() {\n      wrap.scrollBy({ left: -scrollAmt, behavior: 'smooth' });\n    });\n\n    // Drag to scroll\n    var isDown = false, startX, scrollLeft;\n    wrap.addEventListener('mousedown', function(e) {\n      isDown = true;\n      startX = e.pageX - wrap.offsetLeft;\n      scrollLeft = wrap.scrollLeft;\n    });\n    wrap.addEventListener('mouseleave', function() { isDown = false; });\n    wrap.addEventListener('mouseup', function() { isDown = false; });\n    wrap.addEventListener('mousemove', function(e) {\n      if (!isDown) return;\n      e.preventDefault();\n      var x = e.pageX - wrap.offsetLeft;\n      wrap.scrollLeft = scrollLeft - (x - startX);\n    });\n  })();\n</script>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
      }
    },
    "custom_liquid_PBDnJT": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&family=DM+Sans:wght@400;500;600&display=swap');\n\n  .msci-section {\n    background: #ffffff;\n    padding: 48px 0 48px 60px;\n    font-family: 'DM Sans', sans-serif;\n    display: flex;\n    align-items: flex-start;\n    gap: 64px;\n    overflow: hidden;\n    box-sizing: border-box;\n  }\n\n  .msci-left {\n    flex-shrink: 0;\n    width: 300px;\n    display: flex;\n    flex-direction: column;\n  }\n\n  .msci-title {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-weight: 900;\n    font-size: clamp(48px, 5vw, 72px);\n    line-height: 0.95;\n    letter-spacing: -0.01em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    margin: 0 0 16px;\n  }\n\n  .msci-body {\n    font-size: 15px;\n    line-height: 1.7;\n    color: #444444;\n    margin: 0 0 16px;\n  }\n\n  .msci-badges {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 10px 16px;\n  }\n\n  .msci-badge {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n\n  .msci-badge img {\n    width: 20px;\n    height: 20px;\n    object-fit: contain;\n    flex-shrink: 0;\n  }\n\n  .msci-badge span {\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 0.08em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n  }\n\n  .msci-right {\n    flex: 1;\n    overflow: hidden;\n    position: relative;\n    min-width: 0;\n  }\n\n  .msci-right::before,\n  .msci-right::after {\n    content: '';\n    position: absolute;\n    top: 0;\n    bottom: 0;\n    width: 60px;\n    z-index: 2;\n    pointer-events: none;\n  }\n  .msci-right::before {\n    left: 0;\n    background: linear-gradient(to right, #ffffff, transparent);\n  }\n  .msci-right::after {\n    right: 0;\n    background: linear-gradient(to left, #ffffff, transparent);\n  }\n\n  .msci-track-wrap {\n    overflow: hidden;\n    cursor: grab;\n    user-select: none;\n    touch-action: pan-y;\n  }\n  .msci-track-wrap:active { cursor: grabbing; }\n\n  .msci-track {\n    display: flex;\n    gap: 20px;\n    width: max-content;\n    will-change: transform;\n  }\n\n  .msci-card {\n    flex-shrink: 0;\n    width: 300px;\n    background: #F7F7F5;\n    border-radius: 4px;\n    overflow: hidden;\n  }\n\n  .msci-card-img {\n    width: 100%;\n    height: 220px;\n    object-fit: cover;\n    display: block;\n  }\n\n  .msci-card-body {\n    padding: 20px 24px 24px;\n  }\n\n  .msci-card-name {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-weight: 900;\n    font-size: 26px;\n    letter-spacing: 0.01em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    margin: 0 0 10px;\n  }\n\n  .msci-card-tags {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 6px;\n    margin-bottom: 14px;\n  }\n\n  .msci-card-tag {\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 0.1em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    border: 1.5px solid #0A0A0A;\n    border-radius: 999px;\n    padding: 4px 10px;\n  }\n\n  .msci-card-desc {\n    font-size: 13px;\n    line-height: 1.65;\n    color: #555555;\n    margin: 0;\n  }\n\n  @media (max-width: 900px) {\n    .msci-section { flex-direction: column; padding: 40px 24px 48px; gap: 40px; }\n    .msci-left { width: 100%; }\n    .msci-right { overflow: visible; width: 100%; }\n    .msci-right::before, .msci-right::after { display: none; }\n    .msci-track-wrap { overflow: hidden; width: 100%; }\n    .msci-card { width: 260px; }\n    .msci-card-img { height: 180px; }\n  }\n</style>\n\n<section class=\"msci-section\">\n\n  <div class=\"msci-left\">\n    <h2 class=\"msci-title\">CIENCIA<br>EN UN<br>POUCH</h2>\n    <p class=\"msci-body\">Cafeína natural de grano de café verde y vitaminas B en una fórmula absorbida de forma sublingual. Energía real en minutos, sin crash, sin azúcar, sin nicotina.</p>\n    <div class=\"msci-badges\">\n      <div class=\"msci-badge\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Icon_1.svg?v=1776778561\" alt=\"\">\n        <span>Cafeína Natural</span>\n      </div>\n      <div class=\"msci-badge\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Icon_2.svg?v=1776778561\" alt=\"\">\n        <span>Ingredientes Premium</span>\n      </div>\n      <div class=\"msci-badge\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Icon_3.svg?v=1776778560\" alt=\"\">\n        <span>Sin Nicotina</span>\n      </div>\n      <div class=\"msci-badge\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Icon_4.svg?v=1776778560\" alt=\"\">\n        <span>Con Vitaminas B</span>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"msci-right\">\n    <div class=\"msci-track-wrap\" id=\"msci-wrap\">\n      <div class=\"msci-track\" id=\"msci-track\">\n\n        <div class=\"msci-card\">\n          <img class=\"msci-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/PARAXANTHINE_1.webp?v=1776873875\" alt=\"Cafeína Natural\">\n          <div class=\"msci-card-body\">\n            <div class=\"msci-card-name\">Cafeína Natural</div>\n            <div class=\"msci-card-tags\"><span class=\"msci-card-tag\">ENERGÍA</span><span class=\"msci-card-tag\">FOCO</span><span class=\"msci-card-tag\">RENDIMIENTO</span></div>\n            <p class=\"msci-card-desc\">100mg de cafeína natural de granos de café verde. Absorción sublingual para un efecto rápido, limpio y sostenido.</p>\n          </div>\n        </div>\n\n        <div class=\"msci-card\">\n          <img class=\"msci-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/L-THEANINE_1.webp?v=1776874821\" alt=\"L-Teanina\">\n          <div class=\"msci-card-body\">\n            <div class=\"msci-card-name\">L-Teanina</div>\n            <div class=\"msci-card-tags\"><span class=\"msci-card-tag\">CALMA</span><span class=\"msci-card-tag\">ATENCIÓN</span></div>\n            <p class=\"msci-card-desc\">Aminoácido natural que suaviza el efecto de la cafeína, eliminando la ansiedad y potenciando la concentración sostenida.</p>\n          </div>\n        </div>\n\n        <div class=\"msci-card\">\n          <img class=\"msci-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/ALPHA-GPC_1.webp?v=1776874845\" alt=\"Alpha GPC\">\n          <div class=\"msci-card-body\">\n            <div class=\"msci-card-name\">Alpha GPC</div>\n            <div class=\"msci-card-tags\"><span class=\"msci-card-tag\">MEMORIA</span><span class=\"msci-card-tag\">CLARIDAD</span></div>\n            <p class=\"msci-card-desc\">Precursor de acetilcolina que optimiza la formación de memoria, la plasticidad sináptica y el procesamiento cognitivo.</p>\n          </div>\n        </div>\n\n        <div class=\"msci-card\">\n          <img class=\"msci-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/GINSENG_1.webp?v=1776874838\" alt=\"Ginseng\">\n          <div class=\"msci-card-body\">\n            <div class=\"msci-card-name\">Ginseng</div>\n            <div class=\"msci-card-tags\"><span class=\"msci-card-tag\">VITALIDAD</span><span class=\"msci-card-tag\">RESISTENCIA</span></div>\n            <p class=\"msci-card-desc\">Adaptógeno clásico que reduce la fatiga mental y física, mejorando la resistencia al estrés y la concentración prolongada.</p>\n          </div>\n        </div>\n\n        <div class=\"msci-card\">\n          <img class=\"msci-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/VIT-B6_1.webp?v=1776873874\" alt=\"Vitamina B6\">\n          <div class=\"msci-card-body\">\n            <div class=\"msci-card-name\">Vitamina B6</div>\n            <div class=\"msci-card-tags\"><span class=\"msci-card-tag\">ESTADO DE ÁNIMO</span><span class=\"msci-card-tag\">ALERTA</span></div>\n            <p class=\"msci-card-desc\">Vitamina esencial para el metabolismo energético y la producción de neurotransmisores que regulan el humor y la función mental.</p>\n          </div>\n        </div>\n\n        <div class=\"msci-card\">\n          <img class=\"msci-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/VIT-B12.webp?v=1776873874\" alt=\"Vitamina B12\">\n          <div class=\"msci-card-body\">\n            <div class=\"msci-card-name\">Vitamina B12</div>\n            <div class=\"msci-card-tags\"><span class=\"msci-card-tag\">ENERGÍA</span><span class=\"msci-card-tag\">MOTIVACIÓN</span></div>\n            <p class=\"msci-card-desc\">Nutriente clave en la producción de dopamina y serotonina. Apoya el estado de ánimo, la motivación y los niveles de energía sostenidos.</p>\n          </div>\n        </div>\n\n      </div>\n    </div>\n  </div>\n\n</section>\n\n<script>\n(function() {\n  var track = document.getElementById('msci-track');\n  var wrap  = document.getElementById('msci-wrap');\n  if (!track || !wrap) return;\n\n  var GAP    = 20;\n  var cards  = Array.from(track.children);\n  var total  = cards.length;\n  var CARD_W = 0;\n  var offset = 0;\n  var animId = null;\n  var velocity  = 0;\n  var lastX     = 0;\n  var lastTime  = 0;\n  var isDragging = false;\n  var dragStartX = 0;\n  var dragStartOffset = 0;\n\n  function getCardW() {\n    return cards[0].getBoundingClientRect().width + GAP;\n  }\n\n  function init() {\n    cards.forEach(function(c) { track.appendChild(c.cloneNode(true)); });\n    cards.forEach(function(c) { track.insertBefore(c.cloneNode(true), track.firstChild); });\n    CARD_W = getCardW();\n    offset = total * CARD_W;\n    setTransform(offset, false);\n  }\n\n  function setTransform(x, animate) {\n    track.style.transition = animate ? 'transform 0.38s cubic-bezier(0.25,0.46,0.45,0.94)' : 'none';\n    track.style.transform = 'translateX(-' + x + 'px)';\n    offset = x;\n  }\n\n  function checkBounds() {\n    CARD_W = getCardW();\n    var min = CARD_W;\n    var max = total * 2 * CARD_W;\n    if (offset < min) setTransform(offset + total * CARD_W, false);\n    else if (offset > max) setTransform(offset - total * CARD_W, false);\n  }\n\n  function applyMomentum() {\n    if (Math.abs(velocity) < 0.5) {\n      CARD_W = getCardW();\n      var snapped = Math.round(offset / CARD_W) * CARD_W;\n      setTransform(snapped, true);\n      setTimeout(checkBounds, 400);\n      return;\n    }\n    offset += velocity;\n    velocity *= 0.92;\n    track.style.transition = 'none';\n    track.style.transform = 'translateX(-' + offset + 'px)';\n    checkBounds();\n    animId = requestAnimationFrame(applyMomentum);\n  }\n\n  wrap.addEventListener('mousedown', function(e) {\n    isDragging = true;\n    dragStartX = e.clientX;\n    dragStartOffset = offset;\n    lastX = e.clientX;\n    lastTime = Date.now();\n    velocity = 0;\n    if (animId) cancelAnimationFrame(animId);\n    track.style.transition = 'none';\n    e.preventDefault();\n  });\n\n  window.addEventListener('mousemove', function(e) {\n    if (!isDragging) return;\n    var now = Date.now();\n    var dt = now - lastTime || 1;\n    velocity = (lastX - e.clientX) / dt * 16;\n    lastX = e.clientX;\n    lastTime = now;\n    offset = dragStartOffset + (dragStartX - e.clientX);\n    track.style.transform = 'translateX(-' + offset + 'px)';\n    checkBounds();\n  });\n\n  window.addEventListener('mouseup', function() {\n    if (!isDragging) return;\n    isDragging = false;\n    animId = requestAnimationFrame(applyMomentum);\n  });\n\n  wrap.addEventListener('touchstart', function(e) {\n    isDragging = true;\n    dragStartX = e.touches[0].clientX;\n    dragStartOffset = offset;\n    lastX = e.touches[0].clientX;\n    lastTime = Date.now();\n    velocity = 0;\n    if (animId) cancelAnimationFrame(animId);\n    track.style.transition = 'none';\n  }, { passive: true });\n\n  wrap.addEventListener('touchmove', function(e) {\n    if (!isDragging) return;\n    var now = Date.now();\n    var dt = now - lastTime || 1;\n    var cx = e.touches[0].clientX;\n    velocity = (lastX - cx) / dt * 16;\n    lastX = cx;\n    lastTime = now;\n    offset = dragStartOffset + (dragStartX - cx);\n    track.style.transform = 'translateX(-' + offset + 'px)';\n    checkBounds();\n  }, { passive: true });\n\n  wrap.addEventListener('touchend', function() {\n    if (!isDragging) return;\n    isDragging = false;\n    animId = requestAnimationFrame(applyMomentum);\n  }, { passive: true });\n\n  wrap.addEventListener('wheel', function(e) {\n    e.preventDefault();\n    if (animId) cancelAnimationFrame(animId);\n    offset += e.deltaX;\n    track.style.transition = 'none';\n    track.style.transform = 'translateX(-' + offset + 'px)';\n    checkBounds();\n  }, { passive: false });\n\n  init();\n\n  window.addEventListener('resize', function() {\n    CARD_W = getCardW();\n    offset = total * CARD_W;\n    setTransform(offset, false);\n  });\n})();\n</script>",
