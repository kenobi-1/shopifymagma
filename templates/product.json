      "settings": {
        "custom_liquid": "<style>\n  @import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&family=DM+Sans:wght@400;500&display=swap');\n\n  .tr-section {\n    background: #ffffff;\n    padding: 80px 0;\n    overflow: hidden;\n    font-family: 'DM Sans', sans-serif;\n  }\n\n  .tr-header {\n    padding: 0 64px;\n    margin-bottom: 48px;\n    display: flex;\n    align-items: flex-end;\n    justify-content: space-between;\n    gap: 40px;\n  }\n\n  .tr-title {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-weight: 900;\n    font-size: clamp(56px, 7vw, 100px);\n    line-height: 0.88;\n    letter-spacing: -0.02em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    margin: 0;\n  }\n\n  .tr-sub {\n    font-size: 14px;\n    line-height: 1.6;\n    color: #777777;\n    max-width: 280px;\n    text-align: right;\n    flex-shrink: 0;\n  }\n\n  /* Scrollable track */\n  .tr-track-wrap {\n    overflow-x: auto;\n    scrollbar-width: none;\n    -ms-overflow-style: none;\n    cursor: grab;\n    padding: 0 64px 8px;\n  }\n  .tr-track-wrap::-webkit-scrollbar { display: none; }\n  .tr-track-wrap:active { cursor: grabbing; }\n\n  .tr-track {\n    display: flex;\n    gap: 20px;\n    width: max-content;\n  }\n\n  .tr-card {\n    width: 340px;\n    flex-shrink: 0;\n    background: #F7F7F7;\n    display: flex;\n    flex-direction: column;\n    overflow: hidden;\n    transition: transform 0.2s;\n  }\n  .tr-card:hover { transform: translateY(-4px); }\n\n  .tr-card-img {\n    width: 100%;\n    height: 380px;\n    object-fit: cover;\n    object-position: top;\n    display: block;\n    filter: grayscale(20%);\n  }\n\n  .tr-card-body {\n    padding: 24px;\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    gap: 12px;\n  }\n\n  .tr-card-person {\n    display: flex;\n    flex-direction: column;\n    gap: 2px;\n  }\n\n  .tr-card-name {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-weight: 900;\n    font-size: 22px;\n    letter-spacing: -0.01em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n    line-height: 1;\n  }\n\n  .tr-card-role {\n    font-size: 10px;\n    font-weight: 600;\n    letter-spacing: 0.16em;\n    text-transform: uppercase;\n    color: #999999;\n  }\n\n  .tr-stars {\n    color: #F5C518;\n    font-size: 14px;\n    letter-spacing: 2px;\n  }\n\n  .tr-card-quote {\n    font-size: 14px;\n    line-height: 1.65;\n    color: #444444;\n    flex: 1;\n  }\n\n  .tr-card-quote::before { content: '\"'; }\n  .tr-card-quote::after  { content: '\"'; }\n\n  /* Nav arrows */\n  .tr-nav {\n    display: flex;\n    gap: 12px;\n    padding: 32px 64px 0;\n    justify-content: flex-end;\n  }\n\n  .tr-nav-btn {\n    width: 44px;\n    height: 44px;\n    border: 1px solid #DDDDDD;\n    background: #ffffff;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: background 0.2s, border-color 0.2s;\n  }\n  .tr-nav-btn:hover { background: #0A0A0A; border-color: #0A0A0A; }\n  .tr-nav-btn:hover svg { stroke: #ffffff; }\n  .tr-nav-btn svg { stroke: #0A0A0A; transition: stroke 0.2s; }\n\n  @media (max-width: 768px) {\n    .tr-header { padding: 0 24px; flex-direction: column; align-items: flex-start; }\n    .tr-sub { text-align: left; }\n    .tr-track-wrap { padding: 0 24px 8px; }\n    .tr-nav { padding: 24px 24px 0; }\n    .tr-card { width: 280px; }\n    .tr-card-img { height: 300px; }\n  }\n</style>\n\n<section class=\"tr-section\">\n  <div class=\"tr-header\">\n    <h2 class=\"tr-title\">CONFIADO<br>POR EL TOP 1%</h2>\n    <p class=\"tr-sub\">Founders, atletas y ejecutivos de todo el mundo.</p>\n  </div>\n\n  <div class=\"tr-track-wrap\" id=\"tr-track-wrap\">\n    <div class=\"tr-track\" id=\"tr-track\">\n\n      <div class=\"tr-card\">\n        <img class=\"tr-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/fvvrvar_un_titulo_1.png?v=1776811316\" alt=\"Marco R.\">\n        <div class=\"tr-card-body\">\n          <div class=\"tr-card-person\">\n            <div class=\"tr-card-name\">SHEAN Rodríguez</div>\n            <div class=\"tr-card-role\">CEO, Mercado Ventures</div>\n          </div>\n          <div class=\"tr-stars\">★★★★★</div>\n          <div class=\"tr-card-quote\">MAGMA me da el foco que necesito para las reuniones más exigentes. Sin crash, sin ansiedad. Lo uso antes de cada pitch importante.</div>\n        </div>\n      </div>\n\n      <div class=\"tr-card\">\n        <img class=\"tr-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/KyleLui.webp?v=1776800095\" alt=\"Sebastián T.\">\n        <div class=\"tr-card-body\">\n          <div class=\"tr-card-person\">\n            <div class=\"tr-card-name\">Sebastián Torres</div>\n            <div class=\"tr-card-role\">Partner, Kaszek</div>\n          </div>\n          <div class=\"tr-stars\">★★★★★</div>\n          <div class=\"tr-card-quote\">Reemplazó el tercer café del día. Me da energía limpia sin que se note ni en el pulso. Para mí es parte del ritual de trabajo.</div>\n        </div>\n      </div>\n\n      <div class=\"tr-card\">\n        <img class=\"tr-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/fvvrvar_un_titulo_2312cd30-3a9c-41fb-b1e3-30b59a6e89df.png?v=1776811316\" alt=\"Lucía M.\">\n        <div class=\"tr-card-body\">\n          <div class=\"tr-card-person\">\n            <div class=\"tr-card-name\">LUCAS Mansilla</div>\n            <div class=\"tr-card-role\">Atleta profesional, CrossFit</div>\n          </div>\n          <div class=\"tr-stars\">★★★★★</div>\n          <div class=\"tr-card-quote\">Lo uso antes de los WODs más pesados. No me infla, no me pone nerviosa. Solo foco y energía real cuando más lo necesito.</div>\n        </div>\n      </div>\n\n      <div class=\"tr-card\">\n        <img class=\"tr-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/rief.webp?v=1776800095\" alt=\"Andrés V.\">\n        <div class=\"tr-card-body\">\n          <div class=\"tr-card-person\">\n            <div class=\"tr-card-name\">Andrés Villalba</div>\n            <div class=\"tr-card-role\">Co-founder, Ualá</div>\n          </div>\n          <div class=\"tr-stars\">★★★★★</div>\n          <div class=\"tr-card-quote\">Estuve años dependiendo del café. MAGMA es la alternativa que no sabía que existía. Discreta, efectiva, sin los efectos secundarios.</div>\n        </div>\n      </div>\n\n      <div class=\"tr-card\">\n        <img class=\"tr-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/Harley_Miller_4CSCY_1000x1405_6e8887fb-9fe7-4ac2-a1cc-94e4a571ba02.webp?v=1776800133\" alt=\"Federico P.\">\n        <div class=\"tr-card-body\">\n          <div class=\"tr-card-person\">\n            <div class=\"tr-card-name\">Federico Preti</div>\n            <div class=\"tr-card-role\">Director, Accenture Argentina</div>\n          </div>\n          <div class=\"tr-stars\">★★★★★</div>\n          <div class=\"tr-card-quote\">La absorción sublingual es real. En 5 minutos estoy en modo trabajo. Lo llevo a todos lados — reuniones, viajes, gym.</div>\n        </div>\n      </div>\n\n      <div class=\"tr-card\">\n        <img class=\"tr-card-img\" src=\"https://cdn.shopify.com/s/files/1/0784/5848/6820/files/upscalemedia-transformed_1_b43f8cad-b7da-4287-84f1-12b75574292b.webp?v=1776800096\" alt=\"Carolina S.\">\n        <div class=\"tr-card-body\">\n          <div class=\"tr-card-person\">\n            <div class=\"tr-card-name\">AUGUSTO Suárez</div>\n            <div class=\"tr-card-role\">Founder, Studio CS</div>\n          </div>\n          <div class=\"tr-stars\">★★★★★</div>\n          <div class=\"tr-card-quote\">Trabajo hasta las 2 AM regularmente. MAGMA me ayuda a mantener el foco sin arruinar el sueño después. Game changer para creadores.</div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  <div class=\"tr-nav\">\n    <button class=\"tr-nav-btn\" id=\"tr-prev\" aria-label=\"Anterior\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n        <path d=\"M10 3L5 8L10 13\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </button>\n    <button class=\"tr-nav-btn\" id=\"tr-next\" aria-label=\"Siguiente\">\n      <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n        <path d=\"M6 3L11 8L6 13\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </button>\n  </div>\n</section>\n\n<script>\n  (function() {\n    var wrap = document.getElementById('tr-track-wrap');\n    var prev = document.getElementById('tr-prev');\n    var next = document.getElementById('tr-next');\n    var scrollAmt = 360;\n\n    next.addEventListener('click', function() {\n      wrap.scrollBy({ left: scrollAmt, behavior: 'smooth' });\n    });\n    prev.addEventListener('click', function() {\n      wrap.scrollBy({ left: -scrollAmt, behavior: 'smooth' });\n    });\n\n    // Drag to scroll\n    var isDown = false, startX, scrollLeft;\n    wrap.addEventListener('mousedown', function(e) {\n      isDown = true;\n      startX = e.pageX - wrap.offsetLeft;\n      scrollLeft = wrap.scrollLeft;\n    });\n    wrap.addEventListener('mouseleave', function() { isDown = false; });\n    wrap.addEventListener('mouseup', function() { isDown = false; });\n    wrap.addEventListener('mousemove', function(e) {\n      if (!isDown) return;\n      e.preventDefault();\n      var x = e.pageX - wrap.offsetLeft;\n      wrap.scrollLeft = scrollLeft - (x - startX);\n    });\n  })();\n</script>",
