{% comment %}MAGMA ENERGY — Why MAGMA (full-bleed feature rows){% endcomment %}

<style>
  .mwhy {
    background: #080808;
  }

  .mwhy__header {
    padding: clamp(60px,8vw,100px) clamp(24px,5vw,80px) clamp(40px,5vw,64px);
    max-width: 1280px;
    margin: 0 auto;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .mwhy__header-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #00C4B4;
    margin-bottom: 16px;
  }

  .mwhy__header-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(56px, 9vw, 120px);
    line-height: 0.9;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  /* Full-bleed feature row */
  .mwhy__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: clamp(400px, 55vw, 620px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .mwhy__row:last-child { border-bottom: none; }

  .mwhy__row--flip .mwhy__visual { order: 2; }
  .mwhy__row--flip .mwhy__copy   { order: 1; border-left: none; border-right: 1px solid rgba(255,255,255,0.06); }

  .mwhy__visual {
    background: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    min-height: 340px;
  }

  .mwhy__visual-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s ease;
  }

  .mwhy__row:hover .mwhy__visual-img {
    transform: scale(1.03);
  }

  /* Placeholder visual */
  .mwhy__visual-ph {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    width: 100%;
    height: 100%;
    padding: 48px;
  }

  .mwhy__visual-ph-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(100px, 16vw, 220px);
    line-height: 1;
    color: rgba(0,196,180,0.08);
    letter-spacing: -0.02em;
    -webkit-text-stroke: 1px rgba(0,196,180,0.15);
  }

  .mwhy__visual-ph-icon {
    width: 56px;
    height: 56px;
    color: rgba(0,196,180,0.3);
  }

  .mwhy__visual-ph-hint {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.15);
  }

  /* Stat badge */
  .mwhy__stat-badge {
    position: absolute;
    top: 24px;
    left: 24px;
    background: #F5D020;
    color: #000;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 0.04em;
    padding: 6px 16px;
    line-height: 1;
  }

  /* Copy side */
  .mwhy__copy {
    padding: clamp(40px,6vw,80px) clamp(32px,5vw,72px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 24px;
    border-left: 1px solid rgba(255,255,255,0.06);
  }

  .mwhy__copy-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 13px;
    letter-spacing: 0.3em;
    color: rgba(0,196,180,0.6);
  }

  .mwhy__copy-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(44px, 6vw, 80px);
    line-height: 0.95;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .mwhy__copy-body {
    font-size: 15px;
    line-height: 1.75;
    color: rgba(255,255,255,0.5);
    max-width: 420px;
  }

  .mwhy__copy-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 4px;
  }

  .mwhy__copy-list li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: rgba(255,255,255,0.6);
  }

  .mwhy__copy-list li::before {
    content: '';
    display: block;
    width: 16px;
    height: 1px;
    background: #00C4B4;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .mwhy__row {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .mwhy__row--flip .mwhy__visual { order: 1; }
    .mwhy__row--flip .mwhy__copy   { order: 2; border-right: none; border-left: none; }
    .mwhy__copy { border-left: none; }
    .mwhy__visual { min-height: 280px; }
  }
</style>

<section class="mwhy" id="por-que">
  <div class="mwhy__header">
    <p class="mwhy__header-eyebrow magma-animate">Por Qué MAGMA</p>
    <h2 class="mwhy__header-title magma-animate">
      Tres razones<br>
      <span style="color:#00C4B4">para activarte</span>
    </h2>
  </div>

  <!-- Row 1: Energía Limpia -->
  <div class="mwhy__row magma-animate">
    <div class="mwhy__visual">
      {%- if section.settings.image_1 != blank -%}
        <img class="mwhy__visual-img" src="{{ section.settings.image_1 | image_url: width: 900 }}" alt="Energía Limpia" loading="lazy">
      {%- else -%}
        <div class="mwhy__visual-ph">
          <div class="mwhy__visual-ph-num">01</div>
          <svg class="mwhy__visual-ph-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          <span class="mwhy__visual-ph-hint">Agregar imagen</span>
        </div>
      {%- endif -%}
      <div class="mwhy__stat-badge">100mg</div>
    </div>
    <div class="mwhy__copy">
      <div class="mwhy__copy-num">01 — Fórmula</div>
      <h3 class="mwhy__copy-title">Energía<br>Limpia</h3>
      <p class="mwhy__copy-body">100mg de cafeína natural por bolsita. Sin el crash del café, sin los azúcares de las bebidas energéticas.</p>
      <ul class="mwhy__copy-list">
        <li>Cafeína de fuente natural</li>
        <li>Sin picos ni caídas bruscas</li>
        <li>Vitaminas B6, B12, Niacina y Cromo</li>
      </ul>
    </div>
  </div>

  <!-- Row 2: En Cualquier Lugar (flip) -->
  <div class="mwhy__row mwhy__row--flip magma-animate">
    <div class="mwhy__visual">
      {%- if section.settings.image_2 != blank -%}
        <img class="mwhy__visual-img" src="{{ section.settings.image_2 | image_url: width: 900 }}" alt="En Cualquier Lugar" loading="lazy">
      {%- else -%}
        <div class="mwhy__visual-ph">
          <div class="mwhy__visual-ph-num">02</div>
          <svg class="mwhy__visual-ph-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span class="mwhy__visual-ph-hint">Agregar imagen</span>
        </div>
      {%- endif -%}
    </div>
    <div class="mwhy__copy">
      <div class="mwhy__copy-num">02 — Uso</div>
      <h3 class="mwhy__copy-title">En Cualquier<br>Lugar</h3>
      <p class="mwhy__copy-body">Discreta, sin líquidos, sin vapor, sin olor. Una bolsita bajo el labio y listo. Gym, oficina, estudio, viaje.</p>
      <ul class="mwhy__copy-list">
        <li>Sin agua ni preparación</li>
        <li>100% discreta y sin olor</li>
        <li>Lista en segundos</li>
      </ul>
    </div>
  </div>

  <!-- Row 3: Fórmula Completa -->
  <div class="mwhy__row magma-animate">
    <div class="mwhy__visual">
      {%- if section.settings.image_3 != blank -%}
        <img class="mwhy__visual-img" src="{{ section.settings.image_3 | image_url: width: 900 }}" alt="Fórmula Completa" loading="lazy">
      {%- else -%}
        <div class="mwhy__visual-ph">
          <div class="mwhy__visual-ph-num">03</div>
          <svg class="mwhy__visual-ph-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/></svg>
          <span class="mwhy__visual-ph-hint">Agregar imagen</span>
        </div>
      {%- endif -%}
    </div>
    <div class="mwhy__copy">
      <div class="mwhy__copy-num">03 — Ingredientes</div>
      <h3 class="mwhy__copy-title">Fórmula<br>Completa</h3>
      <p class="mwhy__copy-body">No solo cafeína. MAGMA incluye un stack de vitaminas B para rendimiento cognitivo y físico simultáneo.</p>
      <ul class="mwhy__copy-list">
        <li>Vitamina B6 — función nerviosa</li>
        <li>Vitamina B12 — energía celular</li>
        <li>Niacina + Cromo — metabolismo</li>
      </ul>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MAGMA — Why MAGMA",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image_1", "label": "Imagen 1 — Energía Limpia" },
    { "type": "image_picker", "id": "image_2", "label": "Imagen 2 — En Cualquier Lugar" },
    { "type": "image_picker", "id": "image_3", "label": "Imagen 3 — Fórmula Completa" }
  ],
  "presets": [{ "name": "MAGMA — Why MAGMA" }]
}
{% endschema %}
