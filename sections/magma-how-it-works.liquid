{% comment %}MAGMA ENERGY — How It Works{% endcomment %}

<style>
  .magma-how {
    background: var(--color-bg);
    padding: 100px 0;
  }

  .magma-how__header {
    text-align: center;
    margin-bottom: 72px;
  }

  .magma-how__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .magma-how__step {
    background: var(--color-surface);
    padding: 48px 40px 56px;
    position: relative;
    overflow: hidden;
    transition: background 0.3s ease;
  }

  .magma-how__step:hover {
    background: var(--color-surface-2);
  }

  .magma-how__step::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .magma-how__step:hover::before {
    transform: scaleX(1);
  }

  .magma-how__number {
    font-family: var(--font-headline);
    font-size: 100px;
    line-height: 1;
    color: rgba(0, 196, 180, 0.12);
    position: absolute;
    top: 20px;
    right: 24px;
    letter-spacing: -0.02em;
    pointer-events: none;
    transition: color 0.3s ease;
  }

  .magma-how__step:hover .magma-how__number {
    color: rgba(0, 196, 180, 0.2);
  }

  .magma-how__icon {
    width: 48px;
    height: 48px;
    margin-bottom: 24px;
    color: var(--color-accent);
  }

  .magma-how__title {
    font-family: var(--font-headline);
    font-size: 40px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin-bottom: 16px;
    line-height: 1;
  }

  .magma-how__body {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.6);
  }

  @media (max-width: 768px) {
    .magma-how {
      padding: 60px 0;
    }

    .magma-how__grid {
      grid-template-columns: 1fr;
      gap: 2px;
    }

    .magma-how__step {
      padding: 40px 28px;
    }

    .magma-how__number {
      font-size: 70px;
    }
  }
</style>

<section class="magma-how magma-section">
  <div class="magma-container">
    <div class="magma-how__header">
      <div class="magma-eyebrow magma-animate">Así Funciona</div>
      <h2 class="magma-h2 magma-animate">SIMPLE.<br>EFECTIVO.</h2>
    </div>

    <div class="magma-how__grid">
      <div class="magma-how__step magma-animate">
        <span class="magma-how__number">01</span>
        <svg class="magma-how__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
        </svg>
        <h3 class="magma-how__title">Abrí la Lata</h3>
        <p class="magma-how__body">
          Cada lata contiene 15 bolsitas de MAGMA ENERGY. Diseño compacto para llevar a donde vayas.
        </p>
      </div>

      <div class="magma-how__step magma-animate">
        <span class="magma-how__number">02</span>
        <svg class="magma-how__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="10"/>
          <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
          <line x1="9" y1="9" x2="9.01" y2="9"/>
          <line x1="15" y1="9" x2="15.01" y2="9"/>
        </svg>
        <h3 class="magma-how__title">Colocá la Bolsita</h3>
        <p class="magma-how__body">
          Colocá una bolsita entre tu labio y encía. Sin agua, sin vapor, sin ruido. Discreta y cómoda.
        </p>
      </div>

      <div class="magma-how__step magma-animate">
        <span class="magma-how__number">03</span>
        <svg class="magma-how__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
        </svg>
        <h3 class="magma-how__title">Sentí la Energía</h3>
        <p class="magma-how__body">
          100mg de cafeína natural se liberan gradualmente. Energía limpia y sostenida por horas.
        </p>
      </div>
    </div>
  </div>
</section>

