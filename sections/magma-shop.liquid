{% comment %}MAGMA ENERGY — Shop (editorial product showcase){% endcomment %}

<style>
  .mshop {
    background: #080808;
    padding: clamp(60px,10vw,120px) 0;
  }

  .mshop__header {
    padding: 0 clamp(24px,5vw,80px) clamp(40px,5vw,64px);
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .mshop__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(56px, 9vw, 120px);
    line-height: 0.9;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .mshop__title span { color: #00C4B4; }

  .mshop__all {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,0.15);
    padding-bottom: 2px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .mshop__all:hover {
    color: #00C4B4;
    border-color: #00C4B4;
  }

  /* Product grid */
  .mshop__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin: 0 2px;
  }

  .mshop__card {
    background: #111;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: background 0.3s ease;
    overflow: hidden;
  }

  .mshop__card:hover { background: #141414; }

  .mshop__card:hover .mshop__card-img { transform: scale(1.04); }

  /* Image area */
  .mshop__img-wrap {
    aspect-ratio: 3/4;
    overflow: hidden;
    background: #0d0d0d;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .mshop__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16,1,0.3,1);
    display: block;
  }

  /* Placeholder */
  .mshop__img-ph {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    height: 100%;
    padding: 40px;
  }

  .mshop__img-ph-logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(32px, 5vw, 64px);
    line-height: 0.9;
    text-align: center;
    color: rgba(255,255,255,0.08);
    -webkit-text-stroke: 1px rgba(0,196,180,0.15);
  }

  /* Badge */
  .mshop__badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background: #F5D020;
    color: #000;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 0.04em;
    padding: 4px 12px;
    line-height: 1.2;
    z-index: 2;
  }

  .mshop__tag {
    position: absolute;
    top: 16px;
    right: 16px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: rgba(0,196,180,0.15);
    color: #00C4B4;
    border: 1px solid rgba(0,196,180,0.3);
    padding: 4px 10px;
    z-index: 2;
  }

  /* Card body */
  .mshop__card-body {
    padding: 24px 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .mshop__flavor {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #00C4B4;
  }

  .mshop__name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(28px, 4vw, 44px);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    line-height: 1;
    color: #fff;
  }

  .mshop__detail {
    font-size: 12px;
    color: rgba(255,255,255,0.3);
    line-height: 1.5;
    margin-top: 2px;
  }

  .mshop__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .mshop__price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(32px, 4vw, 48px);
    letter-spacing: 0.02em;
    color: #fff;
    line-height: 1;
  }

  .mshop__price .curr {
    font-size: 0.5em;
    color: rgba(255,255,255,0.3);
    vertical-align: top;
    margin-top: 4px;
    display: inline-block;
  }

  .mshop__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #00C4B4;
    color: #000;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 12px 20px;
    text-decoration: none;
    transition: background 0.2s ease;
    border: none;
    cursor: pointer;
  }

  .mshop__btn:hover { background: #00e5d4; }

  /* Coming soon state */
  .mshop__card--soon {
    pointer-events: none;
  }

  .mshop__card--soon .mshop__img-wrap {
    filter: grayscale(1);
    opacity: 0.3;
  }

  .mshop__card--soon .mshop__card-body {
    opacity: 0.35;
  }

  .mshop__soon-label {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
    border: 1px solid rgba(255,255,255,0.1);
    padding: 10px 16px;
  }

  @media (max-width: 900px) {
    .mshop__grid { grid-template-columns: 1fr; }
    .mshop__card--soon { display: none; }
  }
</style>

<section class="mshop" id="comprar">
  <div class="mshop__header">
    <div>
      <p class="magma-eyebrow magma-animate">Shop</p>
      <h2 class="mshop__title magma-animate">Elegí tu<br><span>MAGMA</span></h2>
    </div>
    <a href="/collections/all" class="mshop__all magma-animate">Ver todo →</a>
  </div>

  <div class="mshop__grid">
    {%- if section.settings.collection != blank -%}
      {%- for product in section.settings.collection.products limit: 3 -%}
        <div class="mshop__card magma-animate">
          <div class="mshop__img-wrap">
            {%- if product.featured_image -%}
              <img class="mshop__card-img"
                src="{{ product.featured_image | image_url: width: 700 }}"
                alt="{{ product.title | escape }}"
                loading="lazy" width="700">
            {%- else -%}
              <div class="mshop__img-ph">
                <div class="mshop__img-ph-logo">MAGMA<br>ENERGY</div>
              </div>
            {%- endif -%}
            <div class="mshop__badge">100mg</div>
            <div class="mshop__tag">Disponible</div>
          </div>
          <div class="mshop__card-body">
            <div class="mshop__flavor">{{ product.type | default: 'Menta' }}</div>
            <div class="mshop__name">{{ product.title }}</div>
            <div class="mshop__detail">15 bolsitas · Sin nicotina · Hecho en Argentina</div>
            <div class="mshop__footer">
              <div class="mshop__price">
                <span class="curr">$</span>{{ product.price | money_without_currency }}
              </div>
              <a href="{{ product.url }}" class="mshop__btn">Comprar →</a>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      <!-- Placeholder: 1 real + 2 coming soon -->
      <div class="mshop__card magma-animate">
        <div class="mshop__img-wrap">
          <div class="mshop__img-ph">
            <div class="mshop__img-ph-logo">MAGMA<br>ENERGY</div>
          </div>
          <div class="mshop__badge">100mg</div>
          <div class="mshop__tag">Disponible</div>
        </div>
        <div class="mshop__card-body">
          <div class="mshop__flavor">Menta</div>
          <div class="mshop__name">MAGMA ENERGY</div>
          <div class="mshop__detail">15 bolsitas · Sin nicotina · Hecho en Argentina</div>
          <div class="mshop__footer">
            <div class="mshop__price"><span class="curr">$</span>—</div>
            <a href="/collections/all" class="mshop__btn">Comprar →</a>
          </div>
        </div>
      </div>

      <div class="mshop__card mshop__card--soon magma-animate">
        <div class="mshop__img-wrap">
          <div class="mshop__img-ph">
            <div class="mshop__img-ph-logo">MAGMA<br>ENERGY</div>
          </div>
        </div>
        <div class="mshop__card-body">
          <div class="mshop__flavor">Próximamente</div>
          <div class="mshop__name">Nuevo Sabor</div>
          <div class="mshop__detail">Más sabores en camino</div>
          <div class="mshop__footer">
            <div></div>
            <span class="mshop__soon-label">Pronto</span>
          </div>
        </div>
      </div>

      <div class="mshop__card mshop__card--soon magma-animate">
        <div class="mshop__img-wrap">
          <div class="mshop__img-ph">
            <div class="mshop__img-ph-logo">MAGMA<br>ENERGY</div>
          </div>
        </div>
        <div class="mshop__card-body">
          <div class="mshop__flavor">Próximamente</div>
          <div class="mshop__name">Nuevo Sabor</div>
          <div class="mshop__detail">Más sabores en camino</div>
          <div class="mshop__footer">
            <div></div>
            <span class="mshop__soon-label">Pronto</span>
          </div>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "MAGMA — Shop",
  "tag": "section",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Colección de productos" }
  ],
  "presets": [{ "name": "MAGMA — Shop" }]
}
{% endschema %}
