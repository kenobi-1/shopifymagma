ap: 20px;\n    transition: transform 0.2s;\n  }\n  .rv-card:hover { transform: translateY(-3px); }\n\n  .rv-card-top {}\n\n  .rv-card-stars {\n    color: #F5C518;\n    font-size: 18px;\n    letter-spacing: 2px;\n    margin-bottom: 16px;\n    display: block;\n  }\n\n  .rv-card-text {\n    font-size: 15px;\n    line-height: 1.65;\n    color: #333333;\n    font-weight: 400;\n  }\n\n  .rv-card-bottom {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 12px;\n    padding-top: 20px;\n    border-top: 1px solid #EEEEEE;\n  }\n\n  .rv-card-name {\n    font-family: 'Barlow Condensed', sans-serif;\n    font-weight: 900;\n    font-size: 18px;\n    letter-spacing: 0.02em;\n    text-transform: uppercase;\n    color: #0A0A0A;\n  }\n\n  .rv-card-flavor {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    padding: 5px 10px;\n    border-radius: 20px;\n    white-space: nowrap;\n  }\n\n  .rv-card-flavor.menta {\n    background: rgba(0,201,192,0.1);\n    color: #00968F;\n  }\n\n  .rv-card-flavor.cherry {\n    background: rgba(220,38,38,0.08);\n    color: #B91C1C;\n  }\n\n  .rv-card-flavor::before {\n    content: '✓';\n    font-size: 9px;\n    font-weight: 900;\n  }\n\n  /* Nav + CTA */\n  .rv-footer {\n    padding: 32px 64px 0;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n  }\n\n  .rv-cta {\n    display: inline-flex;\n    align-items: center;\n    gap: 12px;\n    background: #0A0A0A;\n    color: #ffffff;\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 0.16em;\n    text-transform: uppercase;\n    text-decoration: none;\n    padding: 16px 32px;\n    transition: background 0.2s;\n  }\n  .rv-cta:hover { background: #00C9C0; }\n\n  .rv-nav {\n    display: flex;\n    gap: 10px;\n  }\n\n  .rv-nav-btn {\n    width: 44px;\n    height: 44px;\n    border: 1px solid #DDDDDD;\n    background: #ffffff;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: background 0.2s, border-color 0.2s;\n  }\n  .rv-nav-btn:hover { background: #0A0A0A; border-color: #0A0A0A; }\n  .rv-nav-btn:hover svg { stroke: #ffffff; }\n  .rv-nav-btn svg { stroke: #0A0A0A; transition: stroke 0.2s; }\n\n  @media (max-width: 768px) {\n    .rv-header { padding: 0 24px; flex-direction: column; align-items: flex-start; }\n    .rv-rating { align-items: flex-start; }\n    .rv-track-wrap { padding: 0 24px 8px; }\n    .rv-footer { padding: 24px 24px 0; flex-direction: column; align-items: flex-start; gap: 20px; }\n    .rv-card { width: 270px; }\n  }\n</style>\n\n<section class=\"rv-section\">\n  <div class=\"rv-header\">\n    <h2 class=\"rv-title\">LO QUE DICE<br>LA GENTE</h2>\n    <div class=\"rv-rating\">\n      <div class=\"rv-rating-top\">\n        <div class=\"rv-rating-num\">4.9</div>\n        <div class=\"rv-stars-big\">★★★★★</div>\n      </div>\n      <div class=\"rv-rating-sub\">+200 reseñas</div>\n    </div>\n  </div>\n\n  <div class=\"rv-track-wrap\" id=\"rv-wrap\">\n    <div class=\"rv-track\">\n\n      <div class=\"rv-card\">\n        <div class=\"rv-card-top\">\n          <span class=\"rv-card-stars\">★★★★★</span>\n          <p class=\"rv-card-text\">Lo uso después del almuerzo todos los días y el bajón de las 3pm desapareció. Antes dependía del café pero me dejaba sin dormir hasta las 2am.</p>\n        </div>\n        <div class=\"rv-card-bottom\">\n          <div class=\"rv-card-name\">Maximiliano R.</div>\n          <div class=\"rv-card-flavor menta\">Menta</div>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-card-top\">\n          <span class=\"rv-card-stars\">★★★★★</span>\n          <p class=\"rv-card-text\">Me sorprendió que funcione de verdad. Noto la diferencia en 5-10 minutos y es muy suave. No me da ansiedad como el café.</p>\n        </div>\n        <div class=\"rv-card-bottom\">\n          <div class=\"rv-card-name\">Josefina K.</div>\n          <div class=\"rv-card-flavor menta\">Menta</div>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-card-top\">\n          <span class=\"rv-card-stars\">★★★★★</span>\n          <p class=\"rv-card-text\">Si buscás foco instantáneo en un pouch, esto es. Hacía mucho que no me sentía tan concentrado. Game changer para las sesiones largas de estudio.</p>\n        </div>\n        <div class=\"rv-card-bottom\">\n          <div class=\"rv-card-name\">Kevin P.</div>\n          <div class=\"rv-card-flavor cherry\">Cherry</div>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-card-top\">\n          <span class=\"rv-card-stars\">★★★★★</span>\n          <p class=\"rv-card-text\">Intenté bajar el consumo de cafeína 3 veces y fallé. Con MAGMA puedo controlar exactamente cuánto tomo. Energía limpia, sin crash.</p>\n        </div>\n        <div class=\"rv-card-bottom\">\n          <div class=\"rv-card-name\">Dwarkesh S.</div>\n          <div class=\"rv-card-flavor cherry\">Cherry</div>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-card-top\">\n          <span class=\"rv-card-stars\">★★★★★</span>\n          <p class=\"rv-card-text\">Estoy OBSESIONADA con los pouches de menta. Los uso todos los días, en el trabajo y en el gym. El sabor es increíble y la energía dura horas.</p>\n        </div>\n        <div class=\"rv-card-bottom\">\n          <div class=\"rv-card-name\">Claudia T.</div>\n          <div class=\"rv-card-flavor menta\">Menta</div>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-card-top\">\n          <span class=\"rv-card-stars\">★★★★★</span>\n          <p class=\"rv-card-text\">Lo llevo en el bolsillo a todos lados. Para el ranked de noche, para finales, para el pre-gym. Sin lata, sin vaso, sin excusas. 100% recomendado.</p>\n        </div>\n        <div class=\"rv-card-bottom\">\n          <div class=\"rv-card-name\">Matías G.</div>\n          <div class=\"rv-card-flavor cherry\">Cherry</div>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-card-top\">\n          <span class=\"rv-card-stars\">★★★★★</span>\n          <p class=\"rv-card-text\">Trabajo hasta las 3AM regularmente. MAGMA me ayuda a mantener el foco sin arruinar el sueño después. Mucho mejor que cualquier energizante.</p>\n        </div>\n        <div class=\"rv-card-bottom\">\n          <div class=\"rv-card-name\">Carolina V.</div>\n          <div class=\"rv-card-flavor menta\">Menta</div>\n        </div>\n      </div>\n\n      <div class=\"rv-card\">\n        <div class=\"rv-card-top\">\n          <span class=\"rv-card-stars\">★★★★★</span>\n          <p class=\"rv-card-text\">El sabor cherry es adictivo en el buen sentido. Se siente el efecto en minutos y no me da ese temblor que me daban las bebidas energizantes.</p>\n        </div>\n        <div class=\"rv-card-bottom\">\n          <div class=\"rv-card-name\">Rodrigo M.</div>\n          <div class=\"rv-card-flavor cherry\">Cherry</div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  <div class=\"rv-footer\">\n    <a href=\"/collections/all\" class=\"rv-cta\">PROBARLO AHORA →</a>\n    <div class=\"rv-nav\">\n      <button class=\"rv-nav-btn\" id=\"rv-prev\" aria-label=\"Anterior\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n          <path d=\"M10 3L5 8L10 13\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </button>\n      <button class=\"rv-nav-btn\" id=\"rv-next\" aria-label=\"Siguiente\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 16 16\" fill=\"none\">\n          <path d=\"M6 3L11 8L6 13\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </button>\n    </div>\n  </div>\n</section>\n\n<script>\n(function() {\n  var wrap = document.getElementById('rv-wrap');\n  var prev = document.getElementById('rv-prev');\n  var next = document.getElementById('rv-next');\n\n  next.addEventListener('click', function() {\n    wrap.scrollBy({ left: 336, behavior: 'smooth' });\n  });\n  prev.addEventListener('click', function() {\n    wrap.scrollBy({ left: -336, behavior: 'smooth' });\n  });\n\n  // Mouse drag\n  var isDown = false, startX, scrollLeft;\n  wrap.addEventListener('mousedown', function(e) {\n    isDown = true;\n    startX = e.pageX - wrap.offsetLeft;\n    scrollLeft = wrap.scrollLeft;\n  });\n  wrap.addEventListener('mouseleave', function() { isDown = false; });\n  wrap.addEventListener('mouseup', function() { isDown = false; });\n  wrap.addEventListener('mousemove', function(e) {\n    if (!isDown) return;\n    e.preventDefault();\n    var x = e.pageX - wrap.offsetLeft;\n    wrap.scrollLeft = scrollLeft - (x - startX);\n  });\n})();\n</script>",
