{% comment %}MAGMA ENERGY — Hero Section{% endcomment %}

<style>
  .magma-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--color-bg);
    padding-top: 80px;
  }

  /* Background lightning pattern */
  .magma-hero__bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .magma-hero__bg-glow {
    position: absolute;
    top: 20%;
    right: 10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(0, 196, 180, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .magma-hero__bg-glow-2 {
    position: absolute;
    bottom: -10%;
    left: -5%;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(245, 208, 32, 0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  /* Lightning bolt SVG decoratives */
  .magma-hero__bolt {
    position: absolute;
    opacity: 0.08;
  }

  .magma-hero__bolt--1 {
    top: 10%;
    right: 5%;
    width: 120px;
    fill: var(--color-accent);
    transform: rotate(15deg);
  }

  .magma-hero__bolt--2 {
    bottom: 20%;
    left: 3%;
    width: 80px;
    fill: var(--color-energy);
    transform: rotate(-10deg);
  }

  .magma-hero__bolt--3 {
    top: 60%;
    right: 20%;
    width: 60px;
    fill: var(--color-accent);
    transform: rotate(25deg);
  }

  /* Content */
  .magma-hero__content {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 60px;
    max-width: 1280px;
    margin: 0 auto;
    padding: 80px 40px;
    width: 100%;
  }

  .magma-hero__text {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .magma-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .magma-hero__eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-accent);
  }

  .magma-hero__headline {
    font-family: var(--font-headline);
    font-size: clamp(80px, 10vw, 160px);
    line-height: 0.88;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .magma-hero__headline .line-1 {
    display: block;
    color: var(--color-text);
    opacity: 0;
    transform: translateY(40px);
    animation: heroLineIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }

  .magma-hero__headline .line-2 {
    display: block;
    color: var(--color-accent);
    opacity: 0;
    transform: translateY(40px);
    animation: heroLineIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
  }

  .magma-hero__headline .line-3 {
    display: block;
    color: var(--color-energy);
    font-size: clamp(40px, 5vw, 70px);
    opacity: 0;
    transform: translateY(40px);
    animation: heroLineIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.55s forwards;
  }

  @keyframes heroLineIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .magma-hero__body {
    font-size: 17px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
    max-width: 440px;
    opacity: 0;
    animation: heroLineIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;
  }

  .magma-hero__ctas {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    opacity: 0;
    animation: heroLineIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.85s forwards;
  }

  .magma-hero__badges {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 8px;
    opacity: 0;
    animation: heroLineIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) 1s forwards;
  }

  .magma-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.12);
    padding: 6px 12px;
  }

  .magma-hero__badge::before {
    content: '✦';
    color: var(--color-accent);
    font-size: 8px;
  }

  /* Product image */
  .magma-hero__product {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .magma-hero__product-wrap {
    position: relative;
    animation: heroFloat 3.5s ease-in-out infinite;
    opacity: 0;
    animation-delay: 0.6s;
    animation-fill-mode: forwards;
  }

  @keyframes heroFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-16px); }
  }

  /* Use keyframe that handles initial opacity */
  .magma-hero__product-wrap {
    animation: heroFloatIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards,
               heroFloat 3.5s ease-in-out 1.4s infinite;
  }

  @keyframes heroFloatIn {
    from { opacity: 0; transform: scale(0.92) translateY(20px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }

  .magma-hero__product-glow {
    position: absolute;
    inset: -40px;
    background: radial-gradient(circle, rgba(0, 196, 180, 0.18) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .magma-hero__product-img {
    width: 100%;
    max-width: 420px;
    height: auto;
    position: relative;
    z-index: 2;
  }

  .magma-hero__product-placeholder {
    width: 320px;
    height: 320px;
    border-radius: 50%;
    background: var(--color-surface);
    border: 2px solid rgba(0, 196, 180, 0.3);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    position: relative;
    z-index: 2;
  }

  .magma-hero__product-placeholder .brand-name {
    font-family: var(--font-headline);
    font-size: 48px;
    line-height: 0.9;
    text-align: center;
  }

  .magma-hero__product-placeholder .brand-name span {
    display: block;
    color: var(--color-accent);
    font-size: 32px;
  }

  .magma-hero__product-placeholder .product-detail {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .magma-hero__product-placeholder .product-mg {
    background: var(--color-energy);
    color: #000;
    font-size: 13px;
    font-weight: 700;
    padding: 4px 12px;
    margin-top: 4px;
  }

  /* Scroll indicator */
  .magma-hero__scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    opacity: 0;
    animation: heroLineIn 0.7s ease 1.2s forwards;
  }

  .magma-hero__scroll span {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .magma-hero__scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, var(--color-accent), transparent);
    animation: scrollPulse 1.5s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.4; transform: scaleY(0.6); transform-origin: top; }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* Mobile */
  @media (max-width: 900px) {
    .magma-hero__content {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 40px;
      padding: 60px 20px 80px;
    }

    .magma-hero__text {
      align-items: center;
      order: 2;
    }

    .magma-hero__product {
      order: 1;
    }

    .magma-hero__body {
      max-width: 100%;
    }

    .magma-hero__ctas {
      justify-content: center;
    }

    .magma-hero__badges {
      justify-content: center;
    }

    .magma-hero__eyebrow {
      justify-content: center;
    }

    .magma-hero__product-placeholder {
      width: 240px;
      height: 240px;
    }
  }
</style>

<section class="magma-hero" id="inicio">
  <!-- Background -->
  <div class="magma-hero__bg">
    <div class="magma-hero__bg-glow"></div>
    <div class="magma-hero__bg-glow-2"></div>
    <!-- Lightning bolt decoratives -->
    <svg class="magma-hero__bolt magma-hero__bolt--1" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
    <svg class="magma-hero__bolt magma-hero__bolt--2" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
    <svg class="magma-hero__bolt magma-hero__bolt--3" viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
  </div>

  <div class="magma-hero__content">
    <div class="magma-hero__text">
      <div class="magma-hero__eyebrow">Suplemento Dietético — Made in Argentina</div>

      <h1 class="magma-hero__headline">
        <span class="line-1">ENERGÍA</span>
        <span class="line-2">SIN</span>
        <span class="line-3">LÍMITES</span>
      </h1>

      <p class="magma-hero__body">
        100mg de cafeína natural en una bolsita discreta. Sin calorías. Sin azúcar. Sin nicotina.
        La energía que necesitás, cuando la necesitás.
      </p>

      <div class="magma-hero__ctas">
        <a href="#comprar" class="magma-btn magma-btn--primary">
          Comprar Ahora →
        </a>
        <a href="#beneficios" class="magma-btn magma-btn--ghost">
          Ver Beneficios
        </a>
      </div>

      <div class="magma-hero__badges">
        <span class="magma-hero__badge">Sin Calorías</span>
        <span class="magma-hero__badge">Sin Azúcar</span>
        <span class="magma-hero__badge">Sin Nicotina</span>
        <span class="magma-hero__badge">Cafeína Natural</span>
      </div>
    </div>

    <div class="magma-hero__product">
      <div class="magma-hero__product-wrap">
        <div class="magma-hero__product-glow"></div>
        {%- if section.settings.product_image != blank -%}
          <img
            class="magma-hero__product-img"
            src="{{ section.settings.product_image | image_url: width: 800 }}"
            alt="MAGMA ENERGY Pouches"
            width="420"
            loading="eager"
          >
        {%- else -%}
          <div class="magma-hero__product-placeholder">
            <div class="brand-name">
              MAGMA
              <span>ENERGY</span>
            </div>
            <div class="product-detail">15 Pouches · Menta</div>
            <div class="product-mg">100mg Cafeína</div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="magma-hero__scroll" aria-hidden="true">
    <span>Scroll</span>
    <div class="magma-hero__scroll-line"></div>
  </div>
</section>

{% schema %}
{
  "name": "MAGMA — Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Imagen del producto (circular/lata)"
    }
  ],
  "presets": [
    {
      "name": "MAGMA — Hero"
    }
  ]
}
{% endschema %}
