{% comment %}MAGMA ENERGY — Hero v4 (Poster Layout){% endcomment %}

<style>
  .mh {
    position: relative;
    height: 100svh;
    min-height: 640px;
    background: #060606;
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  /* ── Background glow ── */
  .mh__glow {
    position: absolute;
    top: 50%;
    left: 50%;
    translate: -50% -50%;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(0,196,180,.13) 0%, transparent 65%);
    pointer-events: none;
    z-index: 1;
    animation: glowPulse 4s ease-in-out infinite;
  }

  @keyframes glowPulse {
    0%,100% { opacity: .8; transform: scale(1); }
    50%      { opacity: 1; transform: scale(1.08); }
  }

  /* ── Center stack ── */
  .mh__center {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    text-align: center;
    padding: 0 24px;
    width: 100%;
    max-width: 900px;
  }

  /* Top label */
  .mh__label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: .26em;
    text-transform: uppercase;
    color: #00C4B4;
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 12px;
    opacity: 0;
    animation: fadeUp .6s ease .1s forwards;
  }

  .mh__label-dot {
    width: 5px;
    height: 5px;
    background: #00C4B4;
    border-radius: 50%;
    animation: dotPulse 1.8s ease-in-out infinite;
  }

  @keyframes dotPulse {
    0%,100% { opacity: .4; transform: scale(.8); }
    50%      { opacity: 1; transform: scale(1); }
  }

  /* ── Product image ── */
  .mh__img-wrap {
    position: relative;
    width: clamp(260px, 42vmin, 480px);
    height: clamp(260px, 42vmin, 480px);
    margin: 0 auto 28px;
    opacity: 0;
    animation: productIn .9s cubic-bezier(.16,1,.3,1) .2s forwards;
  }

  @keyframes productIn {
    from { opacity:0; transform: scale(.88) translateY(24px); }
    to   { opacity:1; transform: scale(1) translateY(0); }
  }

  /* Float loop starts after entrance */
  .mh__img-wrap { animation: productIn .9s cubic-bezier(.16,1,.3,1) .2s forwards, productFloat 4.5s ease-in-out 1.1s infinite; }

  @keyframes productFloat {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-14px); }
  }

  .mh__img-wrap::before {
    content: '';
    position: absolute;
    inset: -24px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0,196,180,.22) 0%, transparent 70%);
  }

  .mh__product-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 24px 60px rgba(0,196,180,.3));
    border-radius: 50%;
  }

  /* SVG mockup fallback */
  .mh__svg-can {
    width: 100%;
    height: 100%;
  }

  /* ── Floating tags around product ── */
  .mh__tag {
    position: absolute;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.1);
    color: rgba(255,255,255,.55);
    padding: 6px 12px;
    white-space: nowrap;
    backdrop-filter: blur(6px);
    opacity: 0;
    animation: fadeIn .5s ease forwards;
  }

  .mh__tag--1 { top: 10%; left: -10%;  animation-delay: .9s;  }
  .mh__tag--2 { top: 10%; right: -10%; animation-delay: 1.0s; }
  .mh__tag--3 { bottom: 10%; left: -8%;  animation-delay: 1.1s; }
  .mh__tag--4 { bottom: 10%; right: -8%; animation-delay: 1.2s; }

  @keyframes fadeIn { to { opacity:1; } }

  /* ── Headline ── */
  .mh__headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(72px, 13vw, 180px);
    line-height: .88;
    letter-spacing: .02em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .mh__headline .l1 {
    display: block;
    color: #fff;
    opacity: 0;
    clip-path: inset(0 100% 0 0);
    animation: slideIn .7s cubic-bezier(.16,1,.3,1) .55s forwards;
  }

  .mh__headline .l2 {
    display: block;
    color: #00C4B4;
    opacity: 0;
    clip-path: inset(0 100% 0 0);
    animation: slideIn .7s cubic-bezier(.16,1,.3,1) .72s forwards;
  }

  @keyframes slideIn {
    to { opacity:1; clip-path: inset(0 0% 0 0); }
  }

  /* ── Subtext + CTA row ── */
  .mh__bottom {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
    opacity: 0;
    animation: fadeUp .6s ease .95s forwards;
  }

  .mh__desc {
    font-size: 14px;
    line-height: 1.6;
    color: rgba(255,255,255,.45);
    max-width: 340px;
  }

  .mh__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #00C4B4;
    color: #000;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: 18px 36px;
    text-decoration: none;
    transition: background .2s ease, transform .2s ease;
    white-space: nowrap;
  }

  .mh__cta:hover { background: #00e5d4; transform: translateY(-2px); }

  /* ── Scroll cue ── */
  .mh__scroll {
    position: absolute;
    bottom: 28px;
    left: 50%;
    translate: -50% 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    opacity: 0;
    animation: fadeIn .6s ease 1.3s forwards;
  }

  .mh__scroll-line {
    width: 1px;
    height: 44px;
    background: linear-gradient(to bottom, rgba(0,196,180,.7), transparent);
    animation: scrollLine 1.6s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0%   { transform: scaleY(0); transform-origin: top; opacity:0; }
    40%  { transform: scaleY(1); opacity: 1; }
    100% { transform: scaleY(1); transform-origin: bottom; opacity: 0; }
  }

  .mh__scroll-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: rgba(255,255,255,.2);
  }

  @keyframes fadeUp {
    from { opacity:0; transform: translateY(16px); }
    to   { opacity:1; transform: translateY(0); }
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .mh__tag { display: none; }
    .mh__bottom { flex-direction: column; gap: 16px; }
    .mh__desc { text-align: center; }
  }
</style>

<section class="mh" id="inicio">
  <div class="mh__glow" aria-hidden="true"></div>

  <div class="mh__center">

    <div class="mh__label">
      <span class="mh__label-dot"></span>
      Suplemento Dietético · Hecho en Argentina
      <span class="mh__label-dot"></span>
    </div>

    <!-- Product -->
    <div class="mh__img-wrap">
      {%- if section.settings.product_image != blank -%}
        <img
          class="mh__product-img"
          src="{{ section.settings.product_image | image_url: width: 960 }}"
          alt="MAGMA ENERGY Pouches"
          width="480"
          loading="eager"
        >
      {%- else -%}
        <!-- SVG mockup fiel al packaging MAGMA ENERGY -->
        <svg class="mh__svg-can" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <clipPath id="cc"><circle cx="200" cy="200" r="196"/></clipPath>
            <radialGradient id="bg" cx="40%" cy="35%">
              <stop offset="0%" stop-color="#1a7a74"/>
              <stop offset="100%" stop-color="#004d49"/>
            </radialGradient>
          </defs>
          <circle cx="200" cy="200" r="196" fill="url(#bg)"/>
          <!-- Lightning bolts -->
          <g clip-path="url(#cc)" opacity=".5">
            <polygon points="60,10 38,76 56,76 34,142 76,60 54,60" fill="#F5D020"/>
            <polygon points="140,5 118,71 136,71 114,137 156,55 134,55" fill="#F5D020"/>
            <polygon points="230,20 208,86 226,86 204,152 246,70 224,70" fill="#F5D020"/>
            <polygon points="320,8 298,74 316,74 294,140 336,58 314,58" fill="#F5D020"/>
            <polygon points="370,80 348,146 366,146 344,212 386,130 364,130" fill="#F5D020"/>
            <polygon points="20,160 -2,226 16,226 -6,292 36,210 14,210" fill="#F5D020"/>
            <polygon points="376,200 354,266 372,266 350,332 392,250 370,250" fill="#F5D020"/>
            <polygon points="70,310 48,376 66,376 44,398 86,328 64,328" fill="#F5D020"/>
            <polygon points="300,320 278,386 296,386 280,400 316,338 294,338" fill="#F5D020"/>
          </g>
          <!-- Dark band -->
          <rect x="4" y="145" width="392" height="135" fill="#000" opacity=".85" clip-path="url(#cc)"/>
          <!-- MAGMA -->
          <text x="200" y="208" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="82" letter-spacing="2" fill="#fff">MAGMA</text>
          <!-- ENERGY -->
          <text x="200" y="258" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="50" letter-spacing="8" fill="#00C4B4">ENERGY</text>
          <!-- Sub -->
          <text x="200" y="136" text-anchor="middle" font-family="sans-serif" font-size="10" font-weight="700" letter-spacing="2.5" fill="rgba(255,255,255,.6)">SUPLEMENTO DIETÉTICO</text>
          <!-- Bottom info -->
          <text x="200" y="298" text-anchor="middle" font-family="sans-serif" font-size="10" font-weight="600" letter-spacing="2" fill="rgba(255,255,255,.5)">15 POUCHES · MENTA</text>
          <!-- 100mg badge -->
          <rect x="262" y="308" width="96" height="30" rx="15" fill="#F5D020"/>
          <text x="310" y="328" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="19" fill="#000">100mg</text>
          <!-- Ring -->
          <circle cx="200" cy="200" r="196" fill="none" stroke="rgba(0,196,180,.35)" stroke-width="1.5"/>
        </svg>
      {%- endif -%}

      <!-- Floating tags -->
      <div class="mh__tag mh__tag--1">✦ Sin Calorías</div>
      <div class="mh__tag mh__tag--2">✦ Sin Nicotina</div>
      <div class="mh__tag mh__tag--3">✦ Cafeína Natural</div>
      <div class="mh__tag mh__tag--4">✦ Sin Azúcar</div>
    </div>

    <!-- Headline -->
    <h1 class="mh__headline" aria-label="Energía sin límites">
      <span class="l1">ENERGÍA</span>
      <span class="l2">SIN LÍMITES</span>
    </h1>

    <!-- CTA row -->
    <div class="mh__bottom">
      <p class="mh__desc">100mg de cafeína natural por bolsita. Discreta, sin calorías y sin azúcar.</p>
      <a href="#comprar" class="mh__cta">Comprar Ahora →</a>
    </div>

  </div>

  <!-- Scroll cue -->
  <div class="mh__scroll" aria-hidden="true">
    <div class="mh__scroll-line"></div>
    <span class="mh__scroll-label">Scroll</span>
  </div>
</section>

{% schema %}
{
  "name": "MAGMA — Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Imagen del producto"
    }
  ],
  "presets": [{ "name": "MAGMA — Hero" }]
}
{% endschema %}
