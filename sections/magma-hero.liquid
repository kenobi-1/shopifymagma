{% comment %}MAGMA ENERGY — Hero (Editorial rebuild){% endcomment %}

<style>
  .mh {
    position: relative;
    min-height: 100svh;
    background: #080808;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
    padding-top: 0;
  }

  /* Giant watermark text behind everything */
  .mh__watermark {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
  }

  .mh__watermark-text {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(200px, 30vw, 420px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(0, 196, 180, 0.1);
    white-space: nowrap;
    user-select: none;
  }

  /* Teal radial glow */
  .mh__glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(0,196,180,0.10) 0%, transparent 65%);
    pointer-events: none;
    z-index: 2;
  }

  /* Product — absolute center */
  .mh__product {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -52%);
    z-index: 5;
    animation: mhFloat 4s ease-in-out infinite;
  }

  @keyframes mhFloat {
    0%,100% { transform: translate(-50%,-52%) translateY(0); }
    50%      { transform: translate(-50%,-52%) translateY(-18px); }
  }

  .mh__product-img {
    width: clamp(200px, 28vw, 380px);
    height: auto;
    display: block;
    filter: drop-shadow(0 40px 80px rgba(0,196,180,0.25));
  }

  /* Placeholder: SVG mockup de lata circular — fiel al packaging real */
  .mh__product-placeholder {
    width: clamp(240px, 28vw, 380px);
    height: clamp(240px, 28vw, 380px);
    position: relative;
    filter: drop-shadow(0 30px 80px rgba(0,196,180,0.3))
            drop-shadow(0 0 40px rgba(0,196,180,0.15));
  }

  .mh__product-placeholder svg {
    width: 100%;
    height: 100%;
  }

  /* Bottom content block */
  .mh__bottom {
    position: relative;
    z-index: 10;
    padding: 0 clamp(24px, 5vw, 80px) 56px;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: flex-end;
    gap: 40px;
  }

  .mh__headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(88px, 13vw, 200px);
    line-height: 0.85;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    pointer-events: none;
  }

  .mh__headline .w1 {
    display: block;
    color: #fff;
    clip-path: inset(0 100% 0 0);
    animation: mhReveal 0.8s cubic-bezier(0.16,1,0.3,1) 0.15s forwards;
  }

  .mh__headline .w2 {
    display: block;
    color: #00C4B4;
    clip-path: inset(0 100% 0 0);
    animation: mhReveal 0.8s cubic-bezier(0.16,1,0.3,1) 0.35s forwards;
  }

  .mh__headline .w3 {
    display: block;
    color: #F5D020;
    font-size: 0.42em;
    letter-spacing: 0.08em;
    clip-path: inset(0 100% 0 0);
    animation: mhReveal 0.7s cubic-bezier(0.16,1,0.3,1) 0.52s forwards;
  }

  @keyframes mhReveal {
    to { clip-path: inset(0 0% 0 0); }
  }

  .mh__right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 20px;
    padding-bottom: 6px;
    opacity: 0;
    animation: mhFadeUp 0.7s ease 0.8s forwards;
  }

  @keyframes mhFadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .mh__desc {
    font-size: 14px;
    line-height: 1.65;
    color: rgba(255,255,255,0.5);
    max-width: 260px;
    text-align: right;
  }

  .mh__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #00C4B4;
    color: #000;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 16px 28px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }

  .mh__cta:hover {
    background: #00e5d4;
    transform: translateY(-2px);
  }

  /* Side label — rotated */
  .mh__side-label {
    position: absolute;
    right: clamp(16px,3vw,48px);
    top: 50%;
    transform: translateY(-50%) rotate(90deg);
    transform-origin: center;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.2);
    white-space: nowrap;
    z-index: 10;
    pointer-events: none;
  }

  /* Corner brackets */
  .mh__corner {
    position: absolute;
    width: 32px;
    height: 32px;
    z-index: 10;
    pointer-events: none;
  }
  .mh__corner--tl { top: 88px; left: clamp(16px,3vw,48px); border-top: 1px solid rgba(0,196,180,0.4); border-left: 1px solid rgba(0,196,180,0.4); }
  .mh__corner--tr { top: 88px; right: clamp(16px,3vw,48px); border-top: 1px solid rgba(0,196,180,0.4); border-right: 1px solid rgba(0,196,180,0.4); }

  /* Scroll indicator */
  .mh__scroll {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    z-index: 10;
    opacity: 0;
    animation: mhFadeUp 0.6s ease 1.1s forwards;
  }

  .mh__scroll-dot {
    width: 4px;
    height: 4px;
    background: #00C4B4;
    border-radius: 50%;
    animation: mhScrollDot 1.4s ease-in-out infinite;
  }

  .mh__scroll-line {
    width: 1px;
    height: 36px;
    background: linear-gradient(to bottom, rgba(0,196,180,0.6), transparent);
  }

  @keyframes mhScrollDot {
    0%,100% { opacity:0.3; }
    50% { opacity:1; }
  }

  @media (max-width: 768px) {
    .mh__bottom {
      grid-template-columns: 1fr;
      padding-bottom: 40px;
    }
    .mh__right {
      align-items: flex-start;
    }
    .mh__desc {
      text-align: left;
      max-width: 100%;
    }
    .mh__side-label { display: none; }
  }
</style>

<section class="mh" id="inicio">
  <!-- Watermark -->
  <div class="mh__watermark" aria-hidden="true">
    <span class="mh__watermark-text">MAGMA</span>
  </div>

  <!-- Glow -->
  <div class="mh__glow" aria-hidden="true"></div>

  <!-- Corner brackets -->
  <div class="mh__corner mh__corner--tl" aria-hidden="true"></div>
  <div class="mh__corner mh__corner--tr" aria-hidden="true"></div>

  <!-- Side label -->
  <div class="mh__side-label" aria-hidden="true">Menta · 100mg · 15 Bolsitas · Hecho en Argentina</div>

  <!-- Product image -->
  <div class="mh__product">
    {%- if section.settings.product_image != blank -%}
      <img
        class="mh__product-img"
        src="{{ section.settings.product_image | image_url: width: 800 }}"
        alt="MAGMA ENERGY Pouches"
        width="380"
        loading="eager"
      >
    {%- else -%}
      <!-- SVG mockup fiel al packaging real de MAGMA ENERGY -->
      <div class="mh__product-placeholder">
        <svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <clipPath id="circle-clip">
              <circle cx="200" cy="200" r="196"/>
            </clipPath>
            <radialGradient id="bg-grad" cx="40%" cy="35%">
              <stop offset="0%" stop-color="#1a6b6b"/>
              <stop offset="60%" stop-color="#00807a"/>
              <stop offset="100%" stop-color="#005a55"/>
            </radialGradient>
            <radialGradient id="glow" cx="50%" cy="50%">
              <stop offset="0%" stop-color="rgba(0,196,180,0.3)"/>
              <stop offset="100%" stop-color="rgba(0,196,180,0)"/>
            </radialGradient>
          </defs>

          <!-- Base circle -->
          <circle cx="200" cy="200" r="196" fill="url(#bg-grad)"/>

          <!-- Lightning bolt pattern (like the real packaging) -->
          <g clip-path="url(#circle-clip)" opacity="0.55">
            <!-- Yellow lightning bolts scattered -->
            <polygon points="80,20 55,90 75,90 50,160 95,75 72,75" fill="#F5D020"/>
            <polygon points="150,10 125,80 145,80 120,150 165,65 142,65" fill="#F5D020"/>
            <polygon points="240,30 215,100 235,100 210,170 255,85 232,85" fill="#F5D020"/>
            <polygon points="330,15 305,85 325,85 300,155 345,70 322,70" fill="#F5D020"/>
            <polygon points="370,80 345,150 365,150 340,220 385,135 362,135" fill="#F5D020"/>
            <polygon points="30,170 5,240 25,240 0,310 45,225 22,225" fill="#F5D020"/>
            <polygon points="380,200 355,270 375,270 350,340 395,255 372,255" fill="#F5D020"/>
            <polygon points="90,300 65,370 85,370 60,395 105,315 82,315" fill="#F5D020"/>
            <polygon points="300,310 275,380 295,380 270,400 315,325 292,325" fill="#F5D020"/>
            <polygon points="180,330 155,400 175,400 160,400 205,345 182,345" fill="#F5D020"/>
          </g>

          <!-- Dark band across center for text -->
          <rect x="4" y="148" width="392" height="130" fill="#000" opacity="0.82" clip-path="url(#circle-clip)"/>

          <!-- "Suplemento Dietético" small top -->
          <text x="200" y="142" text-anchor="middle" font-family="Inter,sans-serif" font-size="11" font-weight="700" letter-spacing="3" fill="rgba(255,255,255,0.7)" text-decoration="none">SUPLEMENTO DIETÉTICO</text>

          <!-- MAGMA — big -->
          <text x="200" y="208" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="80" letter-spacing="3" fill="#ffffff">MAGMA</text>

          <!-- ENERGY — teal -->
          <text x="200" y="258" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="52" letter-spacing="6" fill="#00C4B4">ENERGY</text>

          <!-- Bottom info -->
          <text x="200" y="298" text-anchor="middle" font-family="Inter,sans-serif" font-size="11" font-weight="600" letter-spacing="2" fill="rgba(255,255,255,0.55)">15 POUCHES DE ENERGÍA · MENTA</text>

          <!-- 100mg badge (yellow pill bottom right) -->
          <rect x="268" y="310" width="90" height="32" rx="16" fill="#F5D020"/>
          <text x="313" y="331" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="20" letter-spacing="1" fill="#000">100mg</text>

          <!-- Cafeína Natural label -->
          <text x="130" y="331" text-anchor="middle" font-family="Inter,sans-serif" font-size="9" font-weight="700" letter-spacing="1.5" fill="rgba(255,255,255,0.4)">CAFEÍNA NATURAL</text>

          <!-- Outer ring -->
          <circle cx="200" cy="200" r="196" fill="none" stroke="rgba(0,196,180,0.4)" stroke-width="1.5"/>
          <circle cx="200" cy="200" r="188" fill="none" stroke="rgba(0,196,180,0.1)" stroke-width="1"/>
        </svg>
      </div>
    {%- endif -%}
  </div>

  <!-- Bottom text block -->
  <div class="mh__bottom">
    <h1 class="mh__headline" aria-label="Energía sin límites">
      <span class="w1">ENERGÍA</span>
      <span class="w2">SIN</span>
      <span class="w3">LÍMITES ·</span>
    </h1>

    <div class="mh__right">
      <p class="mh__desc">
        100mg de cafeína natural. Sin calorías, sin azúcar, sin nicotina. La bolsita que te activa.
      </p>
      <a href="#comprar" class="mh__cta">
        Comprar Ahora →
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="mh__scroll" aria-hidden="true">
    <div class="mh__scroll-dot"></div>
    <div class="mh__scroll-line"></div>
  </div>
</section>

{% schema %}
{
  "name": "MAGMA — Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Imagen del producto"
    }
  ],
  "presets": [{ "name": "MAGMA — Hero" }]
}
{% endschema %}
