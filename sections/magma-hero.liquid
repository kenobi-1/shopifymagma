{% comment %}MAGMA ENERGY — Hero v5 (Full-width split, left-aligned){% endcomment %}

<style>
  /* Remove Dawn page-width constraints */
  .shopify-section:has(.mh) {
    max-width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  .mh {
    position: relative;
    width: 100%;
    min-height: 100svh;
    background: #060606;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    overflow: hidden;
  }

  /* ── LEFT: Text ── */
  .mh__left {
    position: relative;
    z-index: 10;
    padding: 96px 48px 80px 56px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .mh__label {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .26em;
    text-transform: uppercase;
    color: #00C4B4;
    margin-bottom: 36px;
    opacity: 0;
    animation: mhUp .5s ease .1s forwards;
  }

  .mh__label-line {
    display: block;
    width: 28px;
    height: 1px;
    background: #00C4B4;
    flex-shrink: 0;
  }

  .mh__headline {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(80px, 8.5vw, 150px);
    line-height: .88;
    letter-spacing: .02em;
    text-transform: uppercase;
    margin-bottom: 32px;
  }

  .mh__headline .l1 {
    display: block;
    color: #fff;
    clip-path: inset(0 100% 0 0);
    animation: mhReveal .8s cubic-bezier(.16,1,.3,1) .25s forwards;
  }

  .mh__headline .l2 {
    display: block;
    color: #00C4B4;
    clip-path: inset(0 100% 0 0);
    animation: mhReveal .8s cubic-bezier(.16,1,.3,1) .42s forwards;
  }

  .mh__headline .l3 {
    display: block;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255,255,255,.18);
    clip-path: inset(0 100% 0 0);
    animation: mhReveal .7s cubic-bezier(.16,1,.3,1) .56s forwards;
    font-size: .45em;
    letter-spacing: .1em;
  }

  @keyframes mhReveal {
    to { clip-path: inset(0 0% 0 0); }
  }

  .mh__desc {
    font-size: 15px;
    line-height: 1.75;
    color: rgba(255,255,255,.42);
    max-width: 400px;
    margin-bottom: 36px;
    opacity: 0;
    animation: mhUp .6s ease .7s forwards;
  }

  .mh__ctas {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 52px;
    opacity: 0;
    animation: mhUp .6s ease .82s forwards;
  }

  .mh__btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #00C4B4;
    color: #000;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: 18px 40px;
    text-decoration: none;
    transition: background .2s, transform .2s;
  }

  .mh__btn-primary:hover { background: #00e5d4; transform: translateY(-2px); }

  .mh__btn-ghost {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: rgba(255,255,255,.4);
    text-decoration: none;
    border-bottom: 1px solid rgba(255,255,255,.15);
    padding-bottom: 2px;
    transition: color .2s, border-color .2s;
  }

  .mh__btn-ghost:hover { color: #00C4B4; border-color: #00C4B4; }

  .mh__pills {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    opacity: 0;
    animation: mhUp .6s ease .95s forwards;
  }

  .mh__pill {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: rgba(255,255,255,.35);
    border: 1px solid rgba(255,255,255,.1);
    padding: 7px 14px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .mh__pill::before {
    content: '';
    width: 4px;
    height: 4px;
    background: #00C4B4;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── RIGHT: Product ── */
  .mh__right {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    min-height: 100svh;
  }

  /* Glow */
  .mh__right::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(0,196,180,.13) 0%, transparent 65%);
    pointer-events: none;
    animation: glowPulse 4s ease-in-out infinite;
  }

  /* Divider */
  .mh__right::after {
    content: '';
    position: absolute;
    left: 0; top: 12%; height: 76%;
    width: 1px;
    background: linear-gradient(to bottom, transparent, rgba(0,196,180,.18) 30%, rgba(0,196,180,.18) 70%, transparent);
  }

  @keyframes glowPulse {
    0%,100% { opacity:.7; transform: scale(1); }
    50%      { opacity:1;  transform: scale(1.08); }
  }

  .mh__product-wrap {
    position: relative;
    width: clamp(280px, 36vw, 500px);
    height: clamp(280px, 36vw, 500px);
    opacity: 0;
    animation: mhProductIn .9s cubic-bezier(.16,1,.3,1) .3s forwards,
               mhFloat 4.5s ease-in-out 1.2s infinite;
  }

  @keyframes mhProductIn {
    from { opacity:0; transform: scale(.9) translateY(20px); }
    to   { opacity:1; transform: scale(1) translateY(0); }
  }

  @keyframes mhFloat {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-18px); }
  }

  .mh__product-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 32px 80px rgba(0,196,180,.3));
  }

  .mh__svg-can {
    width: 100%;
    height: 100%;
    filter: drop-shadow(0 32px 80px rgba(0,196,180,.3));
  }

  .mh__badge {
    position: absolute;
    top: 4%;
    right: -4%;
    background: #F5D020;
    color: #000;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: .04em;
    padding: 8px 18px;
    line-height: 1;
    opacity: 0;
    animation: mhUp .5s ease 1.1s forwards;
  }

  /* Scroll cue */
  .mh__scroll {
    position: absolute;
    bottom: 32px;
    left: 56px;
    display: flex;
    align-items: center;
    gap: 14px;
    opacity: 0;
    animation: mhUp .5s ease 1.3s forwards;
  }

  .mh__scroll-line {
    width: 44px;
    height: 1px;
    background: rgba(255,255,255,.12);
    position: relative;
    overflow: hidden;
  }

  .mh__scroll-line::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: #00C4B4;
    animation: scrollSlide 2.2s ease-in-out infinite;
  }

  @keyframes scrollSlide {
    0%   { left:-100%; }
    50%  { left:0%; }
    100% { left:100%; }
  }

  .mh__scroll-text {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: rgba(255,255,255,.18);
  }

  @keyframes mhUp {
    from { opacity:0; transform: translateY(14px); }
    to   { opacity:1; transform: translateY(0); }
  }

  /* ── Mobile ── */
  @media (max-width: 860px) {
    .mh {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .mh__right {
      order: 1;
      min-height: 56vw;
    }
    .mh__right::after { display: none; }
    .mh__left {
      order: 2;
      padding: 32px 24px 56px;
      align-items: center;
      text-align: center;
    }
    .mh__pills { justify-content: center; }
    .mh__scroll { left: 50%; translate: -50% 0; }
    .mh__product-wrap {
      width: clamp(220px, 65vw, 320px);
      height: clamp(220px, 65vw, 320px);
    }
  }
</style>

<section class="mh" id="inicio">

  <!-- LEFT -->
  <div class="mh__left">

    <div class="mh__label">
      <span class="mh__label-line"></span>
      Suplemento Dietético · Hecho en Argentina
    </div>

    <h1 class="mh__headline">
      <span class="l1">ENERGÍA</span>
      <span class="l2">SIN</span>
      <span class="l3">LÍMITES ·</span>
    </h1>

    <p class="mh__desc">
      100mg de cafeína natural por bolsita. Sin calorías, sin azúcar, sin nicotina. Para cuando necesitás rendir.
    </p>

    <div class="mh__ctas">
      <a href="#comprar" class="mh__btn-primary">Comprar Ahora →</a>
      <a href="#como-funciona" class="mh__btn-ghost">Cómo funciona</a>
    </div>

    <div class="mh__pills">
      <span class="mh__pill">Sin Calorías</span>
      <span class="mh__pill">Sin Azúcar</span>
      <span class="mh__pill">Sin Nicotina</span>
      <span class="mh__pill">Vitaminas B</span>
    </div>

  </div>

  <!-- RIGHT -->
  <div class="mh__right">
    <div class="mh__product-wrap">

      {%- if section.settings.product_image != blank -%}
        <img
          class="mh__product-img"
          src="{{ section.settings.product_image | image_url: width: 1000 }}"
          alt="MAGMA ENERGY 15 Pouches Menta"
          width="500"
          loading="eager"
        >
      {%- else -%}
        <svg class="mh__svg-can" viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <clipPath id="cc"><circle cx="200" cy="200" r="196"/></clipPath>
            <radialGradient id="bg" cx="40%" cy="35%">
              <stop offset="0%" stop-color="#1a7a74"/>
              <stop offset="100%" stop-color="#004d49"/>
            </radialGradient>
          </defs>
          <circle cx="200" cy="200" r="196" fill="url(#bg)"/>
          <g clip-path="url(#cc)" opacity=".5">
            <polygon points="60,10 38,76 56,76 34,142 76,60 54,60" fill="#F5D020"/>
            <polygon points="140,5 118,71 136,71 114,137 156,55 134,55" fill="#F5D020"/>
            <polygon points="230,20 208,86 226,86 204,152 246,70 224,70" fill="#F5D020"/>
            <polygon points="320,8 298,74 316,74 294,140 336,58 314,58" fill="#F5D020"/>
            <polygon points="370,80 348,146 366,146 344,212 386,130 364,130" fill="#F5D020"/>
            <polygon points="20,160 -2,226 16,226 -6,292 36,210 14,210" fill="#F5D020"/>
            <polygon points="376,200 354,266 372,266 350,332 392,250 370,250" fill="#F5D020"/>
            <polygon points="70,310 48,376 66,376 44,398 86,328 64,328" fill="#F5D020"/>
            <polygon points="300,320 278,386 296,386 280,400 316,338 294,338" fill="#F5D020"/>
          </g>
          <rect x="4" y="145" width="392" height="135" fill="#000" opacity=".85" clip-path="url(#cc)"/>
          <text x="200" y="208" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="82" letter-spacing="2" fill="#fff">MAGMA</text>
          <text x="200" y="258" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="50" letter-spacing="8" fill="#00C4B4">ENERGY</text>
          <text x="200" y="136" text-anchor="middle" font-family="sans-serif" font-size="10" font-weight="700" letter-spacing="2.5" fill="rgba(255,255,255,.6)">SUPLEMENTO DIETÉTICO</text>
          <text x="200" y="298" text-anchor="middle" font-family="sans-serif" font-size="10" font-weight="600" letter-spacing="2" fill="rgba(255,255,255,.5)">15 POUCHES · MENTA</text>
          <rect x="262" y="308" width="96" height="30" rx="15" fill="#F5D020"/>
          <text x="310" y="328" text-anchor="middle" font-family="'Bebas Neue',sans-serif" font-size="19" fill="#000">100mg</text>
          <circle cx="200" cy="200" r="196" fill="none" stroke="rgba(0,196,180,.35)" stroke-width="1.5"/>
        </svg>
      {%- endif -%}

      <div class="mh__badge">100mg ⚡</div>
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="mh__scroll" aria-hidden="true">
    <div class="mh__scroll-line"></div>
    <span class="mh__scroll-text">Scroll</span>
  </div>

</section>

{% schema %}
{
  "name": "MAGMA — Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Imagen del producto"
    }
  ],
  "presets": [{ "name": "MAGMA — Hero" }]
}
{% endschema %}
