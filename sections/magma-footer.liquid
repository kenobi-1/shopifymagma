{% comment %}MAGMA ENERGY — Footer{% endcomment %}

<style>
  .magma-footer {
    background: var(--color-surface);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 72px 0 40px;
  }

  .magma-footer__top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 60px;
    padding-bottom: 60px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .magma-footer__brand-logo {
    font-family: var(--font-headline);
    font-size: 36px;
    letter-spacing: 0.04em;
    line-height: 0.9;
    margin-bottom: 16px;
    text-decoration: none;
    color: var(--color-text);
    display: inline-block;
  }

  .magma-footer__brand-logo span {
    display: block;
    color: var(--color-accent);
    font-size: 24px;
    letter-spacing: 0.1em;
  }

  .magma-footer__brand-desc {
    font-size: 13px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.4);
    max-width: 280px;
    margin-bottom: 24px;
  }

  .magma-footer__socials {
    display: flex;
    gap: 12px;
  }

  .magma-footer__social {
    width: 38px;
    height: 38px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .magma-footer__social:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .magma-footer__col-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: 20px;
  }

  .magma-footer__links {
    display: flex;
    flex-direction: column;
    gap: 12px;
    list-style: none;
  }

  .magma-footer__links a {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    transition: color 0.2s ease;
    letter-spacing: 0.02em;
  }

  .magma-footer__links a:hover {
    color: var(--color-accent);
  }

  .magma-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 32px;
    flex-wrap: wrap;
    gap: 16px;
  }

  .magma-footer__copy {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.04em;
  }

  .magma-footer__copy em {
    color: var(--color-accent);
    font-style: normal;
  }

  .magma-footer__legal {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.25);
    letter-spacing: 0.02em;
    max-width: 500px;
    text-align: right;
  }

  @media (max-width: 900px) {
    .magma-footer__top {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }

    .magma-footer__brand {
      grid-column: 1 / -1;
    }

    .magma-footer__legal {
      text-align: left;
    }
  }

  @media (max-width: 600px) {
    .magma-footer__top {
      grid-template-columns: 1fr;
    }
  }
</style>

<footer class="magma-footer">
  <div class="magma-container">
    <div class="magma-footer__top">
      <div class="magma-footer__brand">
        <a href="/" class="magma-footer__brand-logo">
          MAGMA<span>ENERGY</span>
        </a>
        <p class="magma-footer__brand-desc">
          Energía limpia en una bolsita. Sin calorías, sin azúcar, sin nicotina.
          100mg de cafeína natural. Hecho en Argentina.
        </p>
        <div class="magma-footer__socials">
          <a href="#" class="magma-footer__social" aria-label="Instagram">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href="#" class="magma-footer__social" aria-label="TikTok">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34l-.01-8.83a8.18 8.18 0 0 0 4.78 1.52V4.54a4.85 4.85 0 0 1-1-.85z"/>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <div class="magma-footer__col-title">Comprar</div>
        <ul class="magma-footer__links">
          <li><a href="/collections/all">Todos los Productos</a></li>
          <li><a href="/products/magma-energy-menta">Menta 100mg</a></li>
          <li><a href="#comprar">Nuevos Sabores</a></li>
          <li><a href="#beneficios">Beneficios</a></li>
        </ul>
      </div>

      <div>
        <div class="magma-footer__col-title">Empresa</div>
        <ul class="magma-footer__links">
          <li><a href="/pages/about">Sobre MAGMA</a></li>
          <li><a href="/pages/ingredientes">Ingredientes</a></li>
          <li><a href="/pages/faq">Preguntas Frecuentes</a></li>
          <li><a href="/pages/contact">Contacto</a></li>
        </ul>
      </div>

      <div>
        <div class="magma-footer__col-title">Legal</div>
        <ul class="magma-footer__links">
          <li><a href="/policies/refund-policy">Devoluciones</a></li>
          <li><a href="/policies/privacy-policy">Privacidad</a></li>
          <li><a href="/policies/terms-of-service">Términos</a></li>
          <li><a href="/policies/shipping-policy">Envíos</a></li>
        </ul>
      </div>
    </div>

    <div class="magma-footer__bottom">
      <p class="magma-footer__copy">
        © {{ 'now' | date: '%Y' }} MAGMA ENERGY. Hecho con <em>⚡</em> en Argentina.
      </p>
      <p class="magma-footer__legal">
        MAGMA ENERGY es un suplemento dietético. No es un medicamento. No apto para menores de 18 años, embarazadas ni personas sensibles a la cafeína.
      </p>
    </div>
  </div>
</footer>

