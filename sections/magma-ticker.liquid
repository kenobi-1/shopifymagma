{% comment %}MAGMA ENERGY — Benefits Ticker{% endcomment %}

<style>
  .magma-ticker {
    background: var(--color-surface);
    border-top: 1px solid rgba(0, 196, 180, 0.2);
    border-bottom: 1px solid rgba(0, 196, 180, 0.2);
    padding: 18px 0;
    overflow: hidden;
  }

  .magma-ticker__track {
    display: flex;
    width: max-content;
    animation: ticker 28s linear infinite;
  }

  .magma-ticker__track:hover {
    animation-play-state: paused;
  }

  @keyframes ticker {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .magma-ticker__group {
    display: flex;
    align-items: center;
  }

  .magma-ticker__item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 0 32px;
    white-space: nowrap;
  }

  .magma-ticker__text {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .magma-ticker__sep {
    color: var(--color-energy);
    font-size: 10px;
  }
</style>

{% assign items = '⚡ CAFEÍNA NATURAL|✦ SIN CALORÍAS|✦ SIN AZÚCAR|✦ SIN NICOTINA|✦ VITAMINAS B6 + B12|✦ HECHO EN ARGENTINA|✦ 100MG POR BOLSITA|✦ 15 POUCHES POR LATA' | split: '|' %}

<div class="magma-ticker" id="beneficios" aria-label="Beneficios de MAGMA ENERGY">
  <div class="magma-ticker__track" aria-hidden="true">
    <!-- Duplicated for seamless loop -->
    {% for i in (1..2) %}
    <div class="magma-ticker__group">
      {% for item in items %}
      <div class="magma-ticker__item">
        <span class="magma-ticker__text">{{ item }}</span>
        <span class="magma-ticker__sep">◆</span>
      </div>
      {% endfor %}
    </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "MAGMA — Benefits Ticker",
  "tag": "section",
  "settings": [],
  "presets": [
    {
      "name": "MAGMA — Benefits Ticker"
    }
  ]
}
{% endschema %}
