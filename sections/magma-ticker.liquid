{% comment %}MAGMA ENERGY — Big Editorial Ticker{% endcomment %}

<style>
  .mticker {
    background: #080808;
    border-top: 1px solid rgba(0,196,180,0.15);
    border-bottom: 1px solid rgba(0,196,180,0.15);
    padding: 20px 0;
    overflow: hidden;
  }

  .mticker__track {
    display: flex;
    width: max-content;
    animation: mtickerScroll 22s linear infinite;
  }

  .mticker__track:hover { animation-play-state: paused; }

  @keyframes mtickerScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .mticker__group {
    display: flex;
    align-items: center;
  }

  .mticker__item {
    display: flex;
    align-items: center;
    gap: 0;
    white-space: nowrap;
  }

  .mticker__word {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(60px, 8vw, 96px);
    letter-spacing: 0.04em;
    line-height: 1;
    padding: 0 24px;
  }

  .mticker__word--white { color: #ffffff; }
  .mticker__word--teal  { color: #00C4B4; }

  .mticker__sep {
    color: #F5D020;
    font-size: clamp(20px, 3vw, 36px);
    line-height: 1;
    flex-shrink: 0;
  }
</style>

{% assign words = 'CAFEÍNA NATURAL,SIN CALORÍAS,SIN AZÚCAR,SIN NICOTINA,100MG,HECHO EN ARGENTINA,10 BOLSITAS,VITAMINAS B' | split: ',' %}

<div class="mticker" id="beneficios" aria-label="Beneficios MAGMA ENERGY">
  <div class="mticker__track" aria-hidden="true">
    {% for i in (1..2) %}
    <div class="mticker__group">
      {% for word in words %}
        {% assign mod = forloop.index | modulo: 2 %}
        <div class="mticker__item">
          <span class="mticker__word {% if mod == 0 %}mticker__word--teal{% else %}mticker__word--white{% endif %}">{{ word }}</span>
          <span class="mticker__sep">✦</span>
        </div>
      {% endfor %}
    </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "MAGMA — Big Ticker",
  "tag": "section",
  "settings": [],
  "presets": [{ "name": "MAGMA — Big Ticker" }]
}
{% endschema %}
