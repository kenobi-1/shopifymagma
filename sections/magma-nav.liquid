{% comment %}MAGMA ENERGY — Navigation{% endcomment %}

<style>
  .magma-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 200;
    padding: 20px 0;
    transition: background 0.3s ease, padding 0.3s ease, border-color 0.3s ease;
    border-bottom: 1px solid transparent;
  }

  .magma-nav--scrolled {
    background: rgba(8, 8, 8, 0.95);
    backdrop-filter: blur(12px);
    padding: 14px 0;
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }

  .magma-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .magma-nav__logo {
    font-family: var(--font-headline);
    font-size: 28px;
    letter-spacing: 0.06em;
    color: var(--color-text);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .magma-nav__logo span:first-child {
    color: var(--color-text);
  }

  .magma-nav__logo span:last-child {
    color: var(--color-accent);
    font-size: 20px;
    letter-spacing: 0.1em;
  }

  .magma-nav__links {
    display: flex;
    align-items: center;
    gap: 36px;
    list-style: none;
  }

  .magma-nav__links a {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .magma-nav__links a:hover {
    color: var(--color-accent);
  }

  .magma-nav__actions {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .magma-nav__cart {
    position: relative;
    color: var(--color-text);
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .magma-nav__cart-count {
    position: absolute;
    top: -8px;
    right: -10px;
    background: var(--color-accent);
    color: #000;
    font-size: 10px;
    font-weight: 700;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .magma-nav__cart-count:empty,
  .magma-nav__cart-count[data-count="0"] {
    display: none;
  }

  .magma-nav__buy {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: var(--color-accent);
    color: #000;
    padding: 10px 20px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .magma-nav__buy:hover {
    background: #00ddd0;
    transform: translateY(-1px);
  }

  /* Hamburger */
  .magma-nav__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 4px;
  }

  .magma-nav__hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-text);
    transition: all 0.3s ease;
  }

  /* Mobile menu */
  .magma-nav__mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--color-bg);
    z-index: 300;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 32px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .magma-nav__mobile-menu.is-open {
    opacity: 1;
    pointer-events: all;
  }

  .magma-nav__mobile-menu a {
    font-family: var(--font-headline);
    font-size: 48px;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }

  .magma-nav__mobile-menu a:hover {
    color: var(--color-accent);
  }

  .magma-nav__mobile-close {
    position: absolute;
    top: 24px;
    right: 40px;
    background: none;
    border: none;
    color: var(--color-text);
    font-size: 32px;
    cursor: pointer;
    line-height: 1;
  }

  @media (max-width: 768px) {
    .magma-nav__links,
    .magma-nav__buy {
      display: none;
    }

    .magma-nav__hamburger {
      display: flex;
    }

    .magma-nav__mobile-menu {
      display: flex;
    }

    .magma-nav__inner {
      padding: 0 20px;
    }
  }
</style>

<nav class="magma-nav" role="navigation" aria-label="Principal">
  <div class="magma-nav__inner">
    <a href="/" class="magma-nav__logo">
      <span>MAGMA</span>
      <span>ENERGY</span>
    </a>

    <ul class="magma-nav__links">
      <li><a href="#comprar">Comprar</a></li>
      <li><a href="#beneficios">Beneficios</a></li>
      <li><a href="#por-que">Por Qué MAGMA</a></li>
      <li><a href="#tiendas">Tiendas</a></li>
    </ul>

    <div class="magma-nav__actions">
      <a href="{{ routes.cart_url }}" class="magma-nav__cart" aria-label="Carrito">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span class="magma-nav__cart-count" data-count="{{ cart.item_count }}">
          {{ cart.item_count }}
        </span>
      </a>
      <a href="#comprar" class="magma-nav__buy">Comprar →</a>
    </div>

    <button class="magma-nav__hamburger" aria-label="Menú" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<!-- Mobile menu -->
<div class="magma-nav__mobile-menu" role="dialog" aria-label="Menú de navegación">
  <button class="magma-nav__mobile-close" aria-label="Cerrar menú">✕</button>
  <a href="#comprar">Comprar</a>
  <a href="#beneficios">Beneficios</a>
  <a href="#por-que">Por Qué MAGMA</a>
  <a href="#tiendas">Tiendas</a>
</div>

<script>
  (function () {
    const closeBtn = document.querySelector('.magma-nav__mobile-close');
    const mobileMenu = document.querySelector('.magma-nav__mobile-menu');
    if (closeBtn && mobileMenu) {
      closeBtn.addEventListener('click', () => {
        mobileMenu.classList.remove('is-open');
        document.body.classList.remove('menu-open');
      });
      mobileMenu.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu.classList.remove('is-open');
          document.body.classList.remove('menu-open');
        });
      });
    }
  })();
</script>

{% schema %}
{
  "name": "MAGMA — Navigation",
  "tag": "section",
  "settings": []
}
{% endschema %}
